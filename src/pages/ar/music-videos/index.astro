---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTAButtons from "../../../components/CTAButtons.astro";
import Section from "../../../components/Section.astro";
import { withBase } from "../../../utils/withBase";

const videos = [
  {
    title: "My Way",
    context: "فيديو موسيقي سينمائي بالإنجليزية",
    poster: "/media/music-videos/my-way-thumb.jpg",
    src: "/media/music-videos/my-way-preview.mp4",
    youtubeUrl: "https://youtu.be/VzHMr0Gw0Pg",
    copy:
      "أغنية مصورة بإحساس سينمائي حول الطريق الشخصي والكلفة والحركة والاختيار الذاتي. هنا تظهر معاينة خفيفة، والأغنية الكاملة منشورة على YouTube."
  },
  {
    title: "بيني وبين الأرض",
    context: "فيديو موسيقي عربي شاعري",
    poster: "/media/music-videos/between-me-and-earth-thumb.jpg",
    src: "/media/music-videos/between-me-and-earth-preview.mp4",
    youtubeUrl: "https://youtu.be/TcSlQomJ3F0",
    copy:
      "أغنية عربية حديثة تتحول إلى مشاهد قريبة من الرسم، بحضور شخصي وحركة سردية هادئة. الأغنية الكاملة منشورة على YouTube."
  }
];

const fullSongs = [
  {
    title: "بيني وبين الأرض",
    context: "أغنية عربية أصلية",
    url: "https://youtu.be/TcSlQomJ3F0"
  },
  {
    title: "I Did It My Way",
    context: "فيديو موسيقي سينمائي بالذكاء الاصطناعي",
    url: "https://youtu.be/VzHMr0Gw0Pg"
  },
  {
    title: "What's Going On x What's Up",
    context: "إصدار 2026 / أغنية AI أصلية",
    url: "https://youtu.be/N7T1ouDs9bs"
  },
  {
    title: "What's Going On",
    context: "إصدار 2026 / موسيقى AI أصلية",
    url: "https://youtu.be/E6Rt-agXCYM"
  }
];
---
<BaseLayout
  title="فيديوهات موسيقية أصلية بالذكاء الاصطناعي | تامر منصور"
  description="معاينات وروابط للأغاني الكاملة على YouTube من أعمال تامر منصور الموسيقية والبصرية بالذكاء الاصطناعي."
  path="/ar/music-videos/"
  lang="ar"
  dir="rtl"
  image="/media/music-videos/my-way-thumb.jpg"
  pageType="CollectionPage"
>
  <Section
    title="أغانٍ أصلية تتحول إلى فيديوهات موسيقية سينمائية"
    copy="أغانٍ حديثة تحولت إلى سرد بصري سينمائي. هذه الصفحة تعرض معاينات خفيفة مع روابط مباشرة للأغاني الكاملة على YouTube."
    className="text-right"
  >
    <div class="grid gap-6 lg:grid-cols-2">
      {videos.map((video) => (
        <article class="glass-card overflow-hidden text-right">
          <div class="relative bg-black">
            <video
              controls
              playsinline
              preload="metadata"
              poster={withBase(video.poster)}
              class="aspect-video w-full bg-black object-cover"
              aria-label={`${video.title} music video preview`}
            >
              <source src={withBase(video.src)} type="video/mp4" />
            </video>
          </div>
          <div class="space-y-3 p-5">
            <p class="text-xs uppercase tracking-[0.18em] text-gold">{video.context}</p>
            <h2 class="text-2xl font-semibold tracking-tight text-white">{video.title}</h2>
            <p class="text-sm leading-relaxed text-sand/78">{video.copy}</p>
            <a href={video.youtubeUrl} target="_blank" rel="noopener noreferrer" class="gold-link inline-block text-sm font-semibold">
              شاهد الأغنية الكاملة على YouTube
            </a>
          </div>
        </article>
      ))}
    </div>
  </Section>

  <Section title="ما الذي يظهره العمل الموسيقي" copy="هذا المسار يجمع بين توجيه الأغنية الأصلية بصريًا، بناء صور سينمائية، اتخاذ قرارات مونتاج، وضبط الإيقاع وتجهيز الإصدار للجمهور." className="text-right">
    <div class="grid gap-4 md:grid-cols-3">
      {["تحويل الصوت إلى اتجاه بصري", "نظام صور سينمائي", "تجهيز الإصدار للنشر"].map((item) => (
        <article class="glass-card p-5 text-right">
          <h2 class="text-lg font-semibold text-white">{item}</h2>
        </article>
      ))}
    </div>
  </Section>

  <Section title="الأغاني الكاملة على YouTube" copy="الإصدارات الكاملة منشورة على قناة Tamer AI في YouTube، أما المعاينات هنا فهي للعرض السريع داخل البورتفوليو." className="text-right">
    <div class="grid gap-4 md:grid-cols-2">
      {fullSongs.map((song) => (
        <a href={song.url} target="_blank" rel="noopener noreferrer" class="glass-card block p-5 text-right hover:border-gold/40">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">{song.context}</p>
          <h2 class="mt-3 text-lg font-semibold leading-tight text-white">{song.title}</h2>
          <p class="mt-3 text-sm font-semibold text-gold">افتح الأغنية الكاملة على YouTube</p>
        </a>
      ))}
    </div>
  </Section>

  <Section title="تحتاج اتجاهًا بصريًا لأغنية أو إصدار؟" copy="يمكن استخدام نفس المسار لدعم أغنية، قصة ثقافية، حملة، أو نموذج سينمائي قصير قابل للنشر." className="text-right">
    <CTAButtons bookHref="/ar/contact/" labels={{ book: "ابدأ إصدارًا", whatsapp: "راسلني على واتساب" }} />
  </Section>
</BaseLayout>
