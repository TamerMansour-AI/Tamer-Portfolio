---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTAButtons from "../../../components/CTAButtons.astro";
import Section from "../../../components/Section.astro";
import SmartImage from "../../../components/SmartImage.astro";
import { withBase } from "../../../utils/withBase";
---
<BaseLayout
  title="من أنا | تامر منصور"
  description="تامر منصور يعمل عبر السرد السينمائي والتصميم التعليمي وأنظمة الإنتاج العملية من رام الله مع فرق ومؤسسات عن بعد."
  path="/ar/about/"
  lang="ar"
  dir="rtl"
>
  <Section
    title="عن تامر منصور"
    copy="أعمل في المساحة التي تلتقي فيها القصة والتعليم والأنظمة. بعض المشاريع تحتاج فيلما، وبعضها يحتاج ورشة، وبعضها يحتاج سير عمل يمكن للفريق استخدامه فعلا."
    className="text-right"
  >
    <div class="grid gap-6 lg:grid-cols-[1fr_320px] lg:items-start">
      <div class="grid gap-6 md:grid-cols-2">
        <article class="glass-card p-6">
          <h2 class="text-xl font-semibold text-white">القصة أولا</h2>
          <p class="mt-3 text-sm text-sand/80">
            أبدأ من السؤال الأصلي والتوتر الداخلي والمنطق العاطفي قبل اختيار الأداة أو الصيغة.
          </p>
        </article>
        <article class="glass-card p-6">
          <h2 class="text-xl font-semibold text-white">منهج تعليمي</h2>
          <p class="mt-3 text-sm text-sand/80">
            لا أقدم المخرج النهائي فقط، بل أنقل العملية والحكم والمعيار بحيث يبقى العمل نافعا بعد التسليم.
          </p>
        </article>
        <article class="glass-card p-6">
          <h2 class="text-xl font-semibold text-white">أنظمة تصمد</h2>
          <p class="mt-3 text-sm text-sand/80">
            سواء كانت النتيجة حملة أو ورشة أو نظام إنتاج مدعوما بالذكاء الاصطناعي فأنا أبني للوضوح والتكرار والتنفيذ الهادئ.
          </p>
        </article>
        <article class="glass-card p-6">
          <h2 class="text-xl font-semibold text-white">حكم مهني متجذر</h2>
          <p class="mt-3 text-sm text-sand/80">
            العمل متجذر في رام الله وفي التجربة الحية، لكنه مصاغ ليبقى واضحا عالميا من دون أن يفقد نبرته.
          </p>
        </article>
      </div>
      <article class="glass-card p-5 sm:p-6">
        <div class="mx-auto w-full max-w-[240px] overflow-hidden rounded-3xl border border-white/15 bg-white/5 p-2">
          <SmartImage fallback="/media/profile/profile.png" alt="صورة تامر منصور" class="aspect-square w-full rounded-2xl object-cover" />
        </div>
      </article>
    </div>
  </Section>
  <Section
    title="كيف تتصل هذه الممارسة ببعضها"
    copy="المنهج نفسه يتحرك بين السرد السينمائي والتحويل التعليمي والاستشارة وبناء أنظمة الإنتاج."
    className="text-right"
  >
    <div class="grid gap-4 md:grid-cols-3">
      <article class="glass-card p-6 text-right">
        <h2 class="text-xl font-semibold text-white">الأفكار إلى صور</h2>
        <p class="mt-3 text-sm leading-relaxed text-sand/80">
          مقالات بصرية وأفلام قصيرة وحملات سردية تعطي الأفكار المجردة شكلا أوضح وأثرا عاطفيا أقوى.
        </p>
      </article>
      <article class="glass-card p-6 text-right">
        <h2 class="text-xl font-semibold text-white">التعلم إلى صيغة</h2>
        <p class="mt-3 text-sm leading-relaxed text-sand/80">
          ورش وحوارات تعليمية ووسائط تدريبية تجعل المادة المعقدة أسهل في الفهم والنقاش.
        </p>
      </article>
      <article class="glass-card p-6 text-right">
        <h2 class="text-xl font-semibold text-white">العملية إلى نظام</h2>
        <p class="mt-3 text-sm leading-relaxed text-sand/80">
          أطر أوامر ونقاط مراجعة وأدلة إنتاج تساعد الفرق على الحفاظ على الجودة من دون فوضى.
        </p>
      </article>
    </div>
  </Section>
  <Section
    title="من رام الله إلى تعاون عالمي"
    copy="إذا كنت تحتاج وضوحا سرديا أقوى أو صيغة تعليمية أنضج أو نظام إنتاج يجمع الذوق بالبنية فالخطوة التالية واضحة."
    className="text-right"
  >
    <CTAButtons bookHref="/ar/contact/" labels={{ book: "احجز مكالمة", whatsapp: "راسلني على واتساب" }} />
    <div class="mt-4 flex flex-wrap items-center justify-end gap-4 text-sm">
      <a href={withBase("/ar/work/")} class="gold-link font-semibold">عرض الأعمال المختارة</a>
      <a href={withBase("/ar/services/")} class="text-sand/75 transition hover:text-white">استكشف مسار الخدمات</a>
    </div>
  </Section>
</BaseLayout>
