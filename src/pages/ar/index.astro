---
import CTAButtons from "../../components/CTAButtons.astro";
import SmartImage from "../../components/SmartImage.astro";
import Section from "../../components/Section.astro";
import WorkCard from "../../components/WorkCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { pinterestBoardsAr } from "../../data/pinterest";
import { servicesAr } from "../../data/services";
import { siteData } from "../../data/site";
import { featuredWorkAr } from "../../data/work";
import { withBase } from "../../utils/withBase";

const heroVideo = withBase("/media/hero/hero.mp4");
const heroPoster = withBase("/media/hero/hero-poster.png");
const homeSchema = [
  {
    "@type": "ItemList",
    "@id": "https://tamermansour-ai.github.io/Tamer-Portfolio/ar/#home-highlights",
    name: "أهم مسارات الدليل",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        url: "https://tamermansour-ai.github.io/Tamer-Portfolio/ar/museum-of-echoes/",
        name: "متحف الأصداء"
      },
      {
        "@type": "ListItem",
        position: 2,
        url: "https://tamermansour-ai.github.io/Tamer-Portfolio/ar/literary-reimaginings/",
        name: "إعادة تخيّل الروايات بصريًا"
      },
      {
        "@type": "ListItem",
        position: 3,
        url: "https://tamermansour-ai.github.io/Tamer-Portfolio/ar/book-to-decks/",
        name: "إعادة بناء الكتب كعروض شرائح"
      }
    ]
  }
];
---
<BaseLayout
  title="تامر منصور | سرد بصري بالذكاء الاصطناعي وورشات وأنظمة إبداعية"
  description="أصمم قصصًا بصرية ومنتجات تعليمية وورشات عملية وتجارب رقمية ثنائية اللغة باستخدام الذكاء الاصطناعي بحس إنساني واضح."
  path="/ar/"
  lang="ar"
  dir="rtl"
  image="/media/hero/hero-poster.png"
  pageType="ProfilePage"
  pageHeading={false}
  schema={homeSchema}
>
  <section class="container-shell pt-4 sm:pt-6">
    <div class="overflow-hidden rounded-3xl border border-white/10 bg-white/5">
      <SmartImage
        fallback="/media/hero/hero-poster.png"
        alt="الملصق البصري الرئيسي"
        class="h-[34vh] w-full object-cover sm:h-[44vh] lg:h-[52vh]"
        loading="eager"
      />
    </div>
  </section>

  <section class="container-shell py-14 sm:py-20">
    <div class="grid items-center gap-8 lg:grid-cols-[1.1fr_1fr] lg:gap-10">
      <div class="text-right">
        <p class="text-xs uppercase tracking-[0.22em] text-gold">سرد بصري / ورشات عملية / أنظمة إبداعية</p>
        <h1 class="mt-5 text-3xl font-semibold leading-tight tracking-tight text-white sm:text-5xl">
          أحوّل الأفكار إلى قصص بصرية ومنتجات تعليمية وأنظمة إبداعية قابلة للاستخدام.
        </h1>
        <p class="mt-5 max-w-2xl text-sm leading-relaxed text-sand/85 sm:text-base">
          أساعد الفرق والمؤسسات والمبدعين على الانتقال من التجريب المتناثر بالذكاء الاصطناعي إلى أعمال مكتملة:
          فيديوهات سينمائية، ورشات تفاعلية، منتجات تعليمية، وتجارب رقمية ثنائية اللغة.
        </p>
        <p class="mt-4 max-w-2xl text-sm leading-relaxed text-sand/72 sm:text-[15px]">
          من رام الله، أعمل عن بُعد مع مشاريع تحتاج صورة قوية، بنية واضحة، وحكمًا إنسانيًا في كل مرحلة.
        </p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:justify-end">
          <CTAButtons bookHref="/ar/contact/" labels={{ book: "ابدأ مشروعًا", whatsapp: "راسلني على واتساب" }} />
          <a href={withBase("/ar/work/")} class="inline-flex w-full items-center justify-center rounded-full border border-white/18 px-5 py-3 text-sm font-semibold text-sand hover:border-gold/60 hover:text-white sm:w-auto">
            شاهد الأعمال
          </a>
        </div>
      </div>
      <div class="relative aspect-[4/5] overflow-hidden rounded-3xl border border-white/10 bg-white/5 sm:aspect-video">
        <div
          id="hero-video-fallback-ar"
          class="absolute inset-0 bg-white/5"
        >
          <img src={heroPoster} alt="معاينة بصرية سينمائية لأعمال تامر منصور" class="h-full w-full object-cover" loading="eager" />
        </div>
        <video
          id="hero-video-ar"
          class="absolute inset-0 hidden h-full w-full object-cover"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster={heroPoster}
          aria-label="فيديو تعريفي سينمائي لأعمال تامر منصور بالذكاء الاصطناعي"
        >
          <source src={heroVideo} type="video/mp4" />
        </video>
      </div>
    </div>
  </section>

  <section class="container-shell pb-10 sm:pb-12">
    <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 sm:p-6">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl text-right">
          <p class="text-xs uppercase tracking-[0.22em] text-gold">أعمال تمتد بين الإعلام والتعليم والمنتجات الرقمية</p>
          <h2 class="mt-3 text-xl font-semibold tracking-tight text-white sm:text-2xl">
            أقوى الأعمال منظمة في مسارات واضحة حتى تبقى الصفحة الرئيسية سهلة القراءة.
          </h2>
        </div>
        <p class="max-w-xl text-sm leading-relaxed text-sand/75 text-right">
          يمكنك فهم المدى بسرعة هنا، ثم فتح الصفحات التفصيلية عندما تريد السياق الكامل والوسائط والروابط العامة.
        </p>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.2em] text-gold">أفلام وفيديوهات</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/78">
            أفلام قصصية وفيديوهات موسيقية بالذكاء الاصطناعي.
          </p>
        </article>
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.2em] text-gold">مختبرات حية</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/78">
            مختبرات وورشات تفاعلية منشورة وقابلة للمعاينة.
          </p>
        </article>
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.2em] text-gold">منتجات تعليمية</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/78">
            مواد تعليمية على TPT وتحويل كتب إلى عروض بصرية.
          </p>
        </article>
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.2em] text-gold">مشاريع ثنائية اللغة</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/78">
            مشاريع ثقافية ومعرفية تعمل بالعربية والإنجليزية.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="container-shell pb-8 sm:pb-12">
    <a
      href={withBase("/ar/museum-of-echoes/")}
      class="group grid gap-6 overflow-hidden rounded-[2rem] border border-white/10 bg-[radial-gradient(circle_at_top_right,rgba(212,175,106,0.18),transparent_34%),linear-gradient(140deg,rgba(14,14,14,0.98),rgba(24,24,24,0.96))] p-6 transition hover:border-gold/40 hover:bg-[radial-gradient(circle_at_top_right,rgba(212,175,106,0.24),transparent_34%),linear-gradient(140deg,rgba(14,14,14,0.98),rgba(28,28,28,0.98))] lg:grid-cols-[1.05fr_0.95fr] lg:items-center"
    >
      <div class="space-y-4 text-right">
        <p class="text-xs uppercase tracking-[0.22em] text-gold">مشروع منصة مميزة</p>
        <h2 class="text-2xl font-semibold tracking-tight text-white sm:text-3xl">
          متحف الأصداء يحوّل الموسيقى الأصلية إلى أرشيف استماع ثنائي اللغة.
        </h2>
        <p class="max-w-2xl text-sm leading-relaxed text-sand/80 sm:text-base">
          عالم استماع تتحول فيه القطع إلى غرف ومجموعات ومسارات اكتشاف. صممت منطق المنتج، اتجاه الواجهة، التحرير، وتجربة المنصة العامة.
        </p>
        <div class="flex flex-wrap justify-end gap-2 text-xs uppercase tracking-[0.18em] text-sand/70">
          <span class="rounded-full border border-white/12 px-3 py-1">أرشيف ثنائي اللغة</span>
          <span class="rounded-full border border-white/12 px-3 py-1">استماع تحريري</span>
          <span class="rounded-full border border-white/12 px-3 py-1">منصة عامة حية</span>
        </div>
        <div class="flex flex-wrap items-center justify-end gap-4 text-sm">
          <span class="font-semibold text-gold">افتح متحف الأصداء</span>
          <span class="text-sand/70 transition group-hover:text-white">شاهد صفحة المشروع ثم استكشف المنصة الحية</span>
        </div>
      </div>
      <div class="relative aspect-[4/3] overflow-hidden rounded-[1.5rem] border border-white/10 bg-white/5">
        <SmartImage
          fallback="/media/museum/museum-of-echoes-home.jpg"
          alt="معاينة مشروع متحف الأصداء"
          class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
        />
      </div>
    </a>
  </section>

  <Section
    title="ما الذي أبنيه"
    copy="أجمع بين الإخراج البصري، وبنية التعليم، والإنتاج العملي بالذكاء الاصطناعي حتى تتحول الفكرة إلى عمل قابل للمشاهدة أو الاستخدام."
    className="text-right"
  >
    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      <article class="glass-card p-6">
        <h3 class="text-lg font-semibold text-white">إنتاج فيديو وسرد بصري</h3>
        <p class="mt-3 text-sm text-sand/80">أفلام قصصية وفيديوهات موسيقية ومواد حملات مبنية على جو واضح واستمرارية.</p>
      </article>
      <article class="glass-card p-6">
        <h3 class="text-lg font-semibold text-white">ورشات ومختبرات تعلم</h3>
        <p class="mt-3 text-sm text-sand/80">جلسات عملية مع أنشطة ومصادر وأدوات حية ومخرجات يمكن استخدامها بعد الورشة.</p>
      </article>
      <article class="glass-card p-6">
        <h3 class="text-lg font-semibold text-white">منتجات تعليمية وتصميم معرفة</h3>
        <p class="mt-3 text-sm text-sand/80">حزم دروس بصرية وتحويل كتب إلى عروض وأوراق عمل ومواد جاهزة للمعلمين والمدربين.</p>
      </article>
      <article class="glass-card p-6">
        <h3 class="text-lg font-semibold text-white">نماذج ويب ثنائية اللغة</h3>
        <p class="mt-3 text-sm text-sand/80">صفحات وأرشيفات ومختبرات وأدوات خفيفة تجعل الفكرة قابلة للاستخدام بالعربية والإنجليزية.</p>
      </article>
    </div>
  </Section>

  <Section
    title="أعمال مختارة"
    copy="مجموعة مختارة من مشاريع عامة ومقتطفات مناسبة للعرض توضّح كيف يمتد العمل بين الأفلام، المختبرات التعليمية، المنتجات التربوية، الموسيقى، الأدب، والمنصات الرقمية."
    className="text-right"
  >
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {featuredWorkAr.map((item) => <WorkCard item={item} lang="ar" imageClass="h-48 w-full object-cover" />)}
    </div>
    <div class="mt-8 flex flex-wrap items-center justify-end gap-4 text-sm">
      <a href={withBase("/ar/work/")} class="gold-link font-semibold">عرض مجموعة الأعمال الرئيسية</a>
      <a href={withBase("/ar/services/")} class="text-sand/75 transition hover:text-white">كيف ترتبط هذه الاتجاهات بالخدمات</a>
    </div>
  </Section>

  <section class="container-shell pb-8 sm:pb-12">
    <a
      href={withBase("/ar/literary-reimaginings/")}
      class="group grid gap-6 overflow-hidden rounded-[2rem] border border-white/10 bg-[radial-gradient(circle_at_top_right,rgba(212,175,106,0.18),transparent_34%),linear-gradient(140deg,rgba(14,14,14,0.98),rgba(24,24,24,0.96))] p-6 transition hover:border-gold/40 hover:bg-[radial-gradient(circle_at_top_right,rgba(212,175,106,0.22),transparent_34%),linear-gradient(140deg,rgba(14,14,14,0.98),rgba(28,28,28,0.98))] lg:grid-cols-[1.05fr_0.95fr] lg:items-center"
    >
      <div class="space-y-4 text-right">
        <p class="text-xs uppercase tracking-[0.22em] text-gold">سلسلة سردية مميزة</p>
        <h2 class="text-2xl font-semibold tracking-tight text-white sm:text-3xl">
          إعادة تخيّل الروايات بصريًا تتعامل مع الأدب كتأويل لا كملخص سريع.
        </h2>
        <p class="max-w-2xl text-sm leading-relaxed text-sand/80 sm:text-base">
          سلسلة اقتباسات بصرية تبدأ من <span class="text-white">رجال في الشمس</span> و<span class="text-white">عائد إلى حيفا</span>، وتستخدم سردًا ثنائي اللغة وإخراجًا سينمائيًا للحفاظ على الجو والذاكرة والضغط العاطفي.
        </p>
        <div class="flex flex-wrap justify-end gap-2 text-xs uppercase tracking-[0.18em] text-sand/70">
          <span class="rounded-full border border-white/12 px-3 py-1">روايتان منشورتان</span>
          <span class="rounded-full border border-white/12 px-3 py-1">إصدارات عربية وإنجليزية</span>
          <span class="rounded-full border border-white/12 px-3 py-1">اقتباسات قادمة</span>
        </div>
        <div class="flex flex-wrap items-center justify-end gap-4 text-sm">
          <span class="font-semibold text-gold">افتح السلسلة الأدبية</span>
          <span class="text-sand/70 transition group-hover:text-white">شاهد الأعمال المنشورة وكيف يمكن للسلسلة أن تنمو</span>
        </div>
      </div>
      <div class="relative aspect-[4/3] overflow-hidden rounded-[1.5rem] border border-white/10 bg-white/5">
        <SmartImage
          fallback="/media/literary/men-in-the-sun.svg"
          alt="ملصق سلسلة إعادة تخيل الروايات"
          class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
        />
      </div>
    </a>
  </section>

  <Section title="الخدمات" copy="يمكن أن يبدأ التعاون بفيديو، أو ورشة، أو منتج تعليمي، أو نموذج رقمي ثنائي اللغة. كل مسار يرتبط بأعمال يمكن معاينتها." className="text-right">
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {
        servicesAr.map((service) => (
          <article class="glass-card p-6">
            <h3 class="text-lg font-semibold text-white">{service.title}</h3>
            <p class="mt-3 text-sm text-sand/80">{service.summary}</p>
          </article>
        ))
      }
    </div>
    <a href={withBase("/ar/services/")} class="gold-link mt-8 inline-block text-sm font-semibold">استكشف الخدمات</a>
  </Section>

  <Section
    title="لوحات Pinterest"
    copy="مراجع بصرية مختارة للهوية والأسلوب والاتجاه الإبداعي."
    className="text-right"
  >
    <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
      {
        pinterestBoardsAr.map((board) => (
          <a href={board.url} target="_blank" rel="noopener noreferrer" class="glass-card block overflow-hidden">
            <div class="relative aspect-[4/3] overflow-hidden bg-[radial-gradient(circle_at_20%_20%,rgba(212,175,106,0.28),transparent_40%),linear-gradient(135deg,rgba(30,30,30,0.98),rgba(18,18,18,0.98))]">
              <img
                src={withBase(board.thumbLocal)}
                data-fallback={withBase("/media/pinterest/boards/gallery-muse.jpg")}
                onerror="if (this.dataset.fallback && this.src !== this.dataset.fallback) { this.src = this.dataset.fallback; } else { this.classList.add('hidden'); }"
                alt={board.title}
                loading="lazy"
                class="h-full w-full object-cover"
              />
            </div>
            <div class="space-y-2 p-5 text-right">
              <h3 class="text-lg font-semibold leading-tight text-white">{board.title}</h3>
              <p class="text-sm leading-relaxed text-sand/75">{board.description}</p>
              <p class="text-sm font-semibold text-gold">فتح اللوحة</p>
            </div>
          </a>
        ))
      }
    </div>
  </Section>

  <Section
    title="من أنا"
    copy="أجمع بين الحرفة السردية، وتجريب الذكاء الاصطناعي، والتعليم العملي لبناء أعمال بصرية إنسانية وقابلة للاستخدام."
    className="text-right"
  >
    <a href={withBase("/ar/about/")} class="gold-link text-sm font-semibold">اقرأ القصة الكاملة</a>
  </Section>

  <Section title="هل لديك فكرة تحتاج شكلًا واضحًا؟" copy="أرسل الهدف والجمهور والمدة المتوقعة، وسأقترح المسار الأنسب: فيديو، ورشة، منتج تعليمي، نموذج ويب، أو مرحلة أولى مركزة." className="text-right">
    <CTAButtons bookHref="/ar/contact/" labels={{ book: "ابدأ مشروعًا", whatsapp: "راسلني على واتساب" }} />
    <p class="mt-4 text-sm text-sand/70">{siteData.location}</p>
  </Section>
</BaseLayout>

<script>
  const heroVideo = document.getElementById("hero-video-ar");
  const heroFallback = document.getElementById("hero-video-fallback-ar");

  if (heroVideo instanceof HTMLVideoElement && heroFallback instanceof HTMLElement) {
    heroVideo.addEventListener("loadeddata", () => {
      heroVideo.classList.remove("hidden");
      heroFallback.classList.add("hidden");
    });
  }
</script>
