---
import CTAButtons from "../../components/CTAButtons.astro";
import SmartImage from "../../components/SmartImage.astro";
import Section from "../../components/Section.astro";
import WorkCard from "../../components/WorkCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { pinterestBoardsAr } from "../../data/pinterest";
import { servicesAr } from "../../data/services";
import { siteData } from "../../data/site";
import { featuredWorkAr } from "../../data/work";
import { withBase } from "../../utils/withBase";

const heroVideo = withBase("/media/hero/hero.mp4");
const heroPoster = withBase("/media/hero/hero-poster.png");
---
<BaseLayout
  title="تامر منصور | سرد بصري سينمائي وتدريب وأنظمة إنتاج"
  description="تامر منصور يقدم سردا بصريا سينمائيا مدعوما بالذكاء الاصطناعي، وتدريبا عمليا، وأنظمة إنتاج قابلة للتطبيق للعلامات والفرق والمؤسسات."
  path="/ar/"
  lang="ar"
  dir="rtl"
>
  <section class="container-shell pt-4 sm:pt-6">
    <div class="overflow-hidden rounded-3xl border border-white/10 bg-white/5">
      <SmartImage
        fallback="/media/hero/hero-poster.png"
        alt="الملصق البصري الرئيسي"
        class="h-[34vh] w-full object-cover sm:h-[44vh] lg:h-[52vh]"
        loading="eager"
      />
    </div>
  </section>

  <section class="container-shell py-14 sm:py-20">
    <div class="grid items-center gap-8 lg:grid-cols-[1.1fr_1fr] lg:gap-10">
      <div class="text-right">
        <p class="text-xs uppercase tracking-[0.22em] text-gold">سرد سينمائي * تدريب عملي * تصميم سير عمل بالذكاء الاصطناعي</p>
        <h1 class="mt-5 text-3xl font-semibold leading-tight tracking-tight text-white sm:text-5xl">
          تامر منصور يبني سردا بصريا سينمائيا، وورشات عملية، وأنظمة إنتاج بالذكاء الاصطناعي تبدو إنسانية وتصمد في التنفيذ الحقيقي.
        </h1>
        <p class="mt-5 max-w-2xl text-sm leading-relaxed text-sand/85 sm:text-base">
          أساعد المؤسسين والفرق والمؤسسات على الانتقال من تجريب مبهم للذكاء الاصطناعي إلى اتجاه بصري واضح،
          وسير عمل قابل للتكرار، وثقة أقوى لدى الجمهور.
        </p>
        <p class="mt-4 max-w-2xl text-sm leading-relaxed text-sand/72 sm:text-[15px]">
          من رام الله إلى جمهور أوسع، مع حس إنساني واضح وحكم مهني حاضر في كل مرحلة.
        </p>
        <CTAButtons className="mt-7" bookHref="/ar/contact/" labels={{ book: "احجز مكالمة", whatsapp: "راسلني على واتساب" }} />
      </div>
      <div class="relative aspect-[4/5] overflow-hidden rounded-3xl border border-white/10 bg-white/5 sm:aspect-video">
        <div
          id="hero-video-fallback-ar"
          class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(212,175,106,0.35),transparent_45%),radial-gradient(circle_at_80%_30%,rgba(255,255,255,0.08),transparent_50%),linear-gradient(130deg,rgba(15,15,15,0.95),rgba(30,30,30,0.95))]"
        >
          <div class="flex h-full items-end p-6">
            <div class="text-right">
              <p class="text-xs uppercase tracking-[0.2em] text-gold">Hero Video</p>
              <p class="mt-2 text-sm text-sand/80">الفيديو الرئيسي يظهر تلقائيًا عند توفر الملف.</p>
            </div>
          </div>
        </div>
        <video
          id="hero-video-ar"
          class="absolute inset-0 hidden h-full w-full object-cover"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster={heroPoster}
        >
          <source src={heroVideo} type="video/mp4" />
        </video>
      </div>
    </div>
  </section>

  <section class="container-shell pb-10 sm:pb-12">
    <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 sm:p-6">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl text-right">
          <p class="text-xs uppercase tracking-[0.22em] text-gold">مؤشرات ثقة مبكرة</p>
          <h2 class="mt-3 text-xl font-semibold tracking-tight text-white sm:text-2xl">
            جودة سينمائية، تدريب عملي، وأنظمة إنتاج قادرة على الاستمرار بعد التسليم.
          </h2>
        </div>
        <p class="max-w-xl text-sm leading-relaxed text-sand/75 text-right">
          العمل هنا يجمع بين الإنتاج البصري، وتدريب الفرق، والتواصل الثنائي اللغة، وبناء أنظمة تشغيل واضحة لا تعتمد على الإلهام العابر فقط.
        </p>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.2em] text-gold">حملات بصرية</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/78">
            أفلام وهوية إطلاق ومفاهيم قصيرة مصممة لبناء الثقة ولفت الانتباه.
          </p>
        </article>
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.2em] text-gold">ورشات وتدريب</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/78">
            تدريب تطبيقي للمبدعين والفرق والمؤسسات التي تريد رفع جودة الإنتاج بسرعة.
          </p>
        </article>
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.2em] text-gold">أنظمة سير عمل</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/78">
            أطر أوامر، ونقاط مراجعة، وأدلة تشغيل تقلل الفوضى وتحسن الاتساق.
          </p>
        </article>
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.2em] text-gold">تنفيذ ثنائي اللغة</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/78">
            عرض وتواصل بالإنجليزية والعربية بحس محلي واضح ووضوح عالمي.
          </p>
        </article>
      </div>
    </div>
  </section>

  <Section
    title="ما الذي أقدمه"
    copy="مزيج من الجودة السينمائية والتدريب العملي وتطبيقات الذكاء الاصطناعي القابلة للتنفيذ."
    className="text-right"
  >
    <div class="grid gap-4 sm:grid-cols-3">
      <article class="glass-card p-6">
        <h3 class="text-lg font-semibold text-white">إنتاج سينمائي</h3>
        <p class="mt-3 text-sm text-sand/80">إعلانات وأفلام قصيرة وقصص بصرية مصممة للتأثير والتحويل.</p>
      </article>
      <article class="glass-card p-6">
        <h3 class="text-lg font-semibold text-white">ورش وتدريب</h3>
        <p class="mt-3 text-sm text-sand/80">برامج تطبيقية للفرق والمبدعين لرفع جودة الإنتاج بشكل ثابت.</p>
      </article>
      <article class="glass-card p-6">
        <h3 class="text-lg font-semibold text-white">أنظمة ذكاء اصطناعي</h3>
        <p class="mt-3 text-sm text-sand/80">سير عمل عملي ومكتبات أوامر تساعد فريقك على الإنجاز بسرعة وجودة.</p>
      </article>
    </div>
  </Section>

  <Section
    title="أعمال مختارة"
    copy="أربعة أمثلة رئيسية تجمع بين إعادة السرد الأدبي، والتريلر التراثي، والتعليم البصري المتحرك، وتصميم المعرفة عبر العروض."
    className="text-right"
  >
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {featuredWorkAr.map((item) => <WorkCard item={item} lang="ar" imageClass="h-48 w-full object-cover" />)}
    </div>
    <div class="mt-8 flex flex-wrap items-center justify-end gap-4 text-sm">
      <a href={withBase("/ar/work/")} class="gold-link font-semibold">عرض مجموعة الأعمال الرئيسية</a>
      <a href={withBase("/ar/literary-reimaginings/")} class="text-sand/75 transition hover:text-white">استكشف سلسلة إعادة التخيل الأدبي</a>
      <a href={withBase("/ar/services/")} class="text-sand/75 transition hover:text-white">كيف ترتبط هذه الاتجاهات بالخدمات</a>
    </div>
  </Section>

  <Section title="الخدمات" copy="ابدأ بعرض مركز، ثم وسع العمل إلى بناء نظام أو تدريب فريق إذا كان المشروع يحتاج تنفيذا أعمق." className="text-right">
    <div class="grid gap-4 md:grid-cols-3">
      {
        servicesAr.map((service) => (
          <article class="glass-card p-6">
            <h3 class="text-lg font-semibold text-white">{service.title}</h3>
            <p class="mt-3 text-sm text-sand/80">{service.summary}</p>
          </article>
        ))
      }
    </div>
    <a href={withBase("/ar/services/")} class="gold-link mt-8 inline-block text-sm font-semibold">تفاصيل الخدمات</a>
  </Section>

  <Section
    title="لوحات Pinterest"
    copy="مراجع بصرية مختارة للهوية والأسلوب والاتجاه الإبداعي."
    className="text-right"
  >
    <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
      {
        pinterestBoardsAr.map((board) => (
          <a href={board.url} target="_blank" rel="noreferrer" class="glass-card block overflow-hidden">
            <div class="relative aspect-[4/3] overflow-hidden bg-[radial-gradient(circle_at_20%_20%,rgba(212,175,106,0.28),transparent_40%),linear-gradient(135deg,rgba(30,30,30,0.98),rgba(18,18,18,0.98))]">
              <img
                src={withBase(board.thumbLocal)}
                data-fallback={withBase("/media/pinterest/boards/gallery-muse.jpg")}
                onerror="if (this.dataset.fallback && this.src !== this.dataset.fallback) { this.src = this.dataset.fallback; } else { this.classList.add('hidden'); }"
                alt={board.title}
                loading="lazy"
                class="h-full w-full object-cover"
              />
            </div>
            <div class="space-y-2 p-5 text-right">
              <h3 class="text-lg font-semibold leading-tight text-white">{board.title}</h3>
              <p class="text-sm leading-relaxed text-sand/75">{board.description}</p>
              <p class="text-sm font-semibold text-gold">فتح اللوحة</p>
            </div>
          </a>
        ))
      }
    </div>
  </Section>

  <Section
    title="من أنا"
    copy="تعرف على منهجي في الدمج بين الإخراج البصري والتقنيات الحديثة لبناء أثر مستدام."
    className="text-right"
  >
    <a href={withBase("/ar/about/")} class="gold-link text-sm font-semibold">اقرأ القصة الكاملة</a>
  </Section>

  <Section title="جاهز لمشروعك القادم؟" copy="شاركني هدفك وسأقترح لك أفضل مسار إبداعي وتنفيذي." className="text-right">
    <CTAButtons bookHref="/ar/contact/" labels={{ book: "احجز مكالمة", whatsapp: "راسلني على واتساب" }} />
    <p class="mt-4 text-sm text-sand/70">{siteData.location}</p>
  </Section>
</BaseLayout>

<script>
  const heroVideo = document.getElementById("hero-video-ar");
  const heroFallback = document.getElementById("hero-video-fallback-ar");

  if (heroVideo instanceof HTMLVideoElement && heroFallback instanceof HTMLElement) {
    heroVideo.addEventListener("loadeddata", () => {
      heroVideo.classList.remove("hidden");
      heroFallback.classList.add("hidden");
    });
  }
</script>
