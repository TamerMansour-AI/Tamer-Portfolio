---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTAButtons from "../../../components/CTAButtons.astro";
import Section from "../../../components/Section.astro";
import SmartImage from "../../../components/SmartImage.astro";
import { withBase } from "../../../utils/withBase";

const storeUrl = "https://www.teacherspayteachers.com/store/primary-learning-visualised";
const productLinks = [
  {
    title: "Pushes & Pulls Lesson Pack",
    href: "https://www.teacherspayteachers.com/Product/Forces-Motion-Lesson-1-Complete-Bundle-Pushes-Pulls-15481050"
  },
  {
    title: "Friction Lesson Bundle",
    href: "https://www.teacherspayteachers.com/Product/Forces-Motion-Lesson-2-Friction-Lesson-Bundle-Slides-Video-Worksheets-15549604"
  }
];

const samples = [
  {
    title: "غلاف المنتج",
    src: "/media/education-products/tpt-pushes-pulls-cover.jpg",
    copy: "تغليف واضح لحزمة درس علوم للمرحلة الأساسية."
  },
  {
    title: "منطق الشرائح",
    src: "/media/education-products/tpt-force-direction-slide.jpg",
    copy: "شرح بصري بسيط لاتجاه القوة ومفاهيم الصف."
  },
  {
    title: "فحص الفهم الخاطئ",
    src: "/media/education-products/tpt-friction-stop-think.jpg",
    copy: "أسئلة موجهة للطلاب تساعد على النقاش والتصحيح."
  },
  {
    title: "ورقة عمل قابلة للطباعة",
    src: "/media/education-products/tpt-friction-worksheet.jpg",
    copy: "دليل على طبقة الصف غير المتصلة بالإنترنت."
  }
];
---
<BaseLayout
  title="Primary Learning Visualised | منتجات تعليمية على TPT | تامر منصور"
  description="صفحة دليل عامة لمنتجات Primary Learning Visualised التعليمية على Teachers Pay Teachers: شرائح، أوراق عمل، اختبارات قصيرة، فيديوهات، وتغليف مناسب للمنصة."
  path="/ar/education-products/"
  lang="ar"
  dir="rtl"
  image="/media/education-products/tpt-pushes-pulls-cover.jpg"
  pageType="CreativeWork"
>
  <Section
    title="Primary Learning Visualised"
    copy="مسار منتجات تعليمية عام بالتعاون مع شريك تعليمي في قطر: حزم علوم للمرحلة الأساسية، فيديوهات قصيرة، أوراق عمل، فحوصات فهم، وتغليف جاهز لمنصة TPT."
    className="text-right"
  >
    <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
      <div class="glass-card overflow-hidden">
        <div class="relative aspect-video bg-white/5">
          <SmartImage fallback="/media/education-products/tpt-pushes-pulls-cover.jpg" alt="غلاف حزمة درس Pushes and Pulls" class="h-full w-full object-cover" loading="eager" />
        </div>
      </div>
      <div class="space-y-4">
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">ما الذي يظهره العمل</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/80">
            هذا نظام منتج قابل للتكرار: فكرة منهجية، درس بصري، ورقة عمل، تقييم، مفتاح إجابة، صورة غلاف، نص عرض، وتغليف مناسب للسوق.
          </p>
        </article>
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">دليل عام</p>
          <div class="mt-3 flex flex-wrap justify-end gap-3 text-sm">
            <a href={storeUrl} target="_blank" rel="noopener noreferrer" class="gold-link font-semibold">افتح متجر TPT</a>
            {productLinks.map((item) => (
              <a href={item.href} target="_blank" rel="noopener noreferrer" class="text-sand/75 hover:text-white">{item.title}</a>
            ))}
          </div>
        </article>
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">قيمة المنتج</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/80">
            العمل يجمع بين الحكم التعليمي، الإنتاج بمساعدة الذكاء الاصطناعي، الشرح البصري، تغليف السوق، وأصول جاهزة للاستخدام داخل الصف.
          </p>
        </article>
      </div>
    </div>
  </Section>

  <Section title="نماذج من الأصول" copy="عينة مختارة من الأصول الموجهة للسوق: أغلفة، منطق شرائح، فحوصات فهم، أوراق عمل، ومواد جاهزة للصف." className="text-right">
    <div class="grid gap-5 sm:grid-cols-2">
      {samples.map((sample) => (
        <article class="glass-card overflow-hidden text-right">
          <div class="relative aspect-video bg-white/5">
            <SmartImage fallback={sample.src} alt={sample.title} class="h-full w-full object-cover" />
          </div>
          <div class="p-5">
            <h2 class="text-lg font-semibold text-white">{sample.title}</h2>
            <p class="mt-2 text-sm leading-relaxed text-sand/75">{sample.copy}</p>
          </div>
        </article>
      ))}
    </div>
  </Section>

  <Section title="دليل فيديو قصير" copy="مقطع خفيف يوضح اتجاه الدرس المتحرك بصيغة مناسبة للويب." className="text-right">
    <div class="overflow-hidden rounded-2xl border border-white/10 bg-white/5">
      <video controls playsinline preload="metadata" poster={withBase("/media/education-products/tpt-pushes-pulls-cover.jpg")} class="w-full" aria-label="معاينة فيديو حزمة درس Pushes and Pulls">
        <source src={withBase("/media/education-products/tpt-pushes-pulls-preview.mp4")} type="video/mp4" />
      </video>
    </div>
  </Section>

  <Section title="هل تحتاج نظام منتج تعليمي؟" copy="يمكن للنفس المسار أن يحول درسًا أو ورشة أو فكرة تدريب إلى أصول أوضح يمكن استخدامها فعليًا." className="text-right">
    <CTAButtons bookHref="/ar/contact/" labels={{ book: "ابدأ مشروعًا", whatsapp: "راسلني على واتساب" }} />
  </Section>
</BaseLayout>
