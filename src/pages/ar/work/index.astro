---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTAButtons from "../../../components/CTAButtons.astro";
import Section from "../../../components/Section.astro";
import SmartImage from "../../../components/SmartImage.astro";
import WorkCard from "../../../components/WorkCard.astro";
import { pinterestPlaceholderAr, workItemsAr } from "../../../data/work";
import { withBase } from "../../../utils/withBase";

const workSchema = {
  "@type": "ItemList",
  name: "الأعمال المختارة",
  itemListElement: workItemsAr.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: item.url?.startsWith("/") ? `https://tamermansour-ai.github.io/Tamer-Portfolio${item.url}` : item.url,
    name: item.title
  }))
};
---
<BaseLayout
  title="أعمال مختارة | قصص بصرية ومختبرات تعلم ومنتجات تعليمية ومنصات رقمية | تامر منصور"
  description="أعمال عامة مختارة لتامر منصور في الأفلام بالذكاء الاصطناعي، مختبرات التعلم، المنتجات التعليمية، الفيديوهات الموسيقية، وتحويل الكتب إلى عروض ومنصات رقمية ثنائية اللغة."
  path="/ar/work/"
  lang="ar"
  dir="rtl"
  pageType="CollectionPage"
  schema={workSchema}
>
  <Section
    title="أعمال مختارة"
    copy="مجموعة من الأعمال التي يمكن عرضها علنًا: قصص بصرية سينمائية، مختبرات تعلم حية، منتجات تعليمية، فيديوهات موسيقية، أنظمة تحويل كتب إلى عروض، ومنصات رقمية ثنائية اللغة."
    className="text-right"
  >
    <div class="mb-8 grid gap-4 md:grid-cols-3">
      <article class="glass-card p-5 text-right">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">سرد بصري سينمائي</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          أفلام مدعومة بالذكاء الاصطناعي، إعادة تخيّل أدبي، فيديوهات موسيقية، وعوالم بصرية يكون فيها السرد هو الأساس.
        </p>
      </article>
      <article class="glass-card p-5 text-right">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">أنظمة تعلم عملية</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          ورشات، مختبرات، حزم تعليمية، وتجارب موجهة تجعل الذكاء الاصطناعي ممارسة ملموسة لا مجرد عنوان عام.
        </p>
      </article>
      <article class="glass-card p-5 text-right">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">منتجات رقمية</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          منصات ثنائية اللغة، أرشيفات، نماذج أولية، وواجهات تجعل المواد الكثيفة قابلة للاستخدام والفهم.
        </p>
      </article>
    </div>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {workItemsAr.map((item) => <WorkCard item={item} lang="ar" imageClass="h-52 w-full object-cover" />)}
    </div>
    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      <a
        href={withBase("/ar/museum-of-echoes/")}
        class="group grid gap-5 overflow-hidden rounded-[1.75rem] border border-white/10 bg-[radial-gradient(circle_at_top_right,rgba(212,175,106,0.16),transparent_34%),linear-gradient(145deg,rgba(15,15,15,0.98),rgba(22,22,22,0.96))] p-5 text-right transition hover:border-gold/40 hover:bg-[radial-gradient(circle_at_top_right,rgba(212,175,106,0.2),transparent_34%),linear-gradient(145deg,rgba(15,15,15,0.98),rgba(28,28,28,0.98))]"
      >
        <div class="relative aspect-[4/3] overflow-hidden rounded-[1.35rem] border border-white/10 bg-white/5">
          <SmartImage
            fallback="/media/museum/museum-of-echoes-home.jpg"
            alt="معاينة مشروع متحف الأصداء"
            class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
          />
        </div>
        <div class="space-y-4">
          <p class="text-xs uppercase tracking-[0.2em] text-gold">مشروع مميز</p>
          <h3 class="text-2xl font-semibold tracking-tight text-white">متحف الأصداء</h3>
          <p class="text-sm leading-relaxed text-sand/80">
            أرشيف استماع ثنائي اللغة يثبت كيف يمكن أن يمتد الإخراج الإبداعي إلى منطق المنتج، وبنية الاكتشاف، ومنصة ثقافية عامة لها حضورها الخاص.
          </p>
          <div class="flex flex-wrap justify-end gap-2 text-xs uppercase tracking-[0.16em] text-sand/70">
            <span class="rounded-full border border-white/12 px-3 py-1">أرشيف ثنائي اللغة</span>
            <span class="rounded-full border border-white/12 px-3 py-1">موسيقى أصلية</span>
            <span class="rounded-full border border-white/12 px-3 py-1">دليل منتجي</span>
          </div>
          <div class="flex flex-wrap items-center justify-end gap-4 text-sm">
            <span class="font-semibold text-gold">افتح صفحة المشروع</span>
            <span class="text-sand/70 transition group-hover:text-white">شاهد سياق المنصة ثم افتح التجربة الحية</span>
          </div>
        </div>
      </a>
      <a
        href={withBase("/ar/literary-reimaginings/")}
        class="group grid gap-5 overflow-hidden rounded-[1.75rem] border border-white/10 bg-[radial-gradient(circle_at_top_right,rgba(212,175,106,0.16),transparent_34%),linear-gradient(145deg,rgba(15,15,15,0.98),rgba(22,22,22,0.96))] p-5 text-right transition hover:border-gold/40 hover:bg-[radial-gradient(circle_at_top_right,rgba(212,175,106,0.2),transparent_34%),linear-gradient(145deg,rgba(15,15,15,0.98),rgba(28,28,28,0.98))]"
      >
        <div class="space-y-4">
          <p class="text-xs uppercase tracking-[0.2em] text-gold">سلسلة مميزة</p>
          <h3 class="text-2xl font-semibold tracking-tight text-white">إعادة تخيّل الروايات بصريًا</h3>
          <p class="text-sm leading-relaxed text-sand/80">
            وجهة سردية مخصصة لأعمال الاقتباس الروائي، تجمع الإصدارات الثنائية اللغة مع سياق أوضح للمستقبل ودعوة أكثر نضجا للتعاون أو التكليف أو الدعم.
          </p>
          <div class="flex flex-wrap justify-end gap-2 text-xs uppercase tracking-[0.16em] text-sand/70">
            <span class="rounded-full border border-white/12 px-3 py-1">رجال في الشمس</span>
            <span class="rounded-full border border-white/12 px-3 py-1">عائد إلى حيفا</span>
            <span class="rounded-full border border-white/12 px-3 py-1">إصدارات ثنائية اللغة</span>
          </div>
          <div class="flex flex-wrap items-center justify-end gap-4 text-sm">
            <span class="font-semibold text-gold">ادخل إلى السلسلة</span>
            <span class="text-sand/70 transition group-hover:text-white">مدخل مخصص للسلسلة البصرية الكاملة</span>
          </div>
        </div>
        <div class="relative aspect-[4/3] overflow-hidden rounded-[1.35rem] border border-white/10 bg-white/5">
          <SmartImage
            fallback="/media/literary/returning-to-haifa.svg"
            alt="ملصق مميز لسلسلة إعادة تخيل الروايات"
            class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
          />
        </div>
      </a>
    </div>
  </Section>
  <Section title={pinterestPlaceholderAr.title} copy={pinterestPlaceholderAr.description} className="text-right">
    <a href={pinterestPlaceholderAr.url} class="gold-link text-sm font-semibold" target="_blank" rel="noopener noreferrer">
      افتح لوحات Pinterest
    </a>
  </Section>
  <Section
    title="هل تحتاج هذا النوع من الاتجاه لحملة أو برنامج أو نظام إنتاج؟"
    copy="إذا كان المشروع يحتاج وضوحًا سرديًا أو تعلمًا عمليًا أو بنية إنتاج أقوى، فمسارات الخدمات جاهزة."
    className="text-right"
  >
    <CTAButtons bookHref="/ar/contact/" labels={{ book: "ابدأ مشروعًا", whatsapp: "راسلني على واتساب" }} />
    <div class="mt-4 flex flex-wrap items-center justify-end gap-4 text-sm">
      <a href={withBase("/ar/services/")} class="gold-link font-semibold">استكشف الخدمات</a>
      <a href={withBase("/ar/about/")} class="text-sand/75 transition hover:text-white">اقرأ كيف يجمع هذا النهج بين القصة والتعليم والأنظمة</a>
    </div>
  </Section>
</BaseLayout>
