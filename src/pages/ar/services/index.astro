---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTAButtons from "../../../components/CTAButtons.astro";
import Section from "../../../components/Section.astro";
import SmartImage from "../../../components/SmartImage.astro";
import { servicesAr } from "../../../data/services";
import { withBase } from "../../../utils/withBase";

const serviceSchema = servicesAr.map((service) => ({
  "@type": "Service",
  name: service.title,
  description: service.summary,
  provider: {
    "@type": "Person",
    name: "Tamer Mansour",
    url: "https://tamermansour-ai.github.io/Tamer-Portfolio/ar/"
  },
  areaServed: "Remote",
  availableLanguage: ["Arabic", "English"],
  isRelatedTo: {
    "@type": "CreativeWork",
    name: service.proofTitle,
    url: `https://tamermansour-ai.github.io/Tamer-Portfolio${service.proofHref}`
  }
}));
---
<BaseLayout
  title="خدمات تامر منصور | السرد البصري والورشات وأنظمة الإنتاج"
  description="خدمات تامر منصور في صياغة القصة بصريا وأنظمة الإنتاج بالذكاء الاصطناعي والورشات العملية مع ربط واضح بين العرض والدليل."
  path="/ar/services/"
  lang="ar"
  dir="rtl"
  image="/media/services/services-ar.png"
  pageType="CollectionPage"
  schema={serviceSchema}
>
  <section class="container-shell pt-6 sm:pt-8">
    <div class="services-hero overflow-hidden rounded-3xl border border-white/10 bg-white/5">
      <SmartImage
        fallback="/media/services/services-ar.png"
        alt="الملصق التعريفي للخدمات"
        class="services-hero-img w-full"
        loading="eager"
      />
    </div>
  </section>

  <Section
    title="خدمات مصممة لخطوة تالية واضحة"
    copy="ابدأ بالعرض التمهيدي عندما يكون الاتجاه لا يزال ضبابيا. انتقل إلى بناء النظام عندما يكون الاتجاه واضحا لكن التنفيذ متعثرًا. واختر الورشات عندما يكون المطلوب بناء قدرة ومعايير مشتركة."
    className="text-right"
  >
    <div class="mb-8 grid gap-4 md:grid-cols-3">
      <article class="glass-card p-5 text-right">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">ابدأ من هنا</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          المدخل الصحيح يتحدد بحسب ما إذا كانت المشكلة في الصياغة أو التنفيذ أو بناء القدرة. هذه الصفحة مصممة لجعل الفرق واضحا بسرعة.
        </p>
      </article>
      <article class="glass-card p-5 text-right">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">ما الذي تغير</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          كل خدمة أدناه ترتبط الآن بدليل واضح داخل البورتفوليو، حتى تصبح الثقة مبنية على عمل ملموس لا على وصف تجريدي فقط.
        </p>
      </article>
      <article class="glass-card p-5 text-right">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">منطق الخطوة التالية</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          أولا اختر الخدمة التي تطابق العقدة الفعلية. ثم شاهد الدليل. ثم افتح مسار التواصل المناسب.
        </p>
      </article>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {
        servicesAr.map((service) => (
          <article class="glass-card p-6 text-right">
            <h2 class="text-xl font-semibold text-white">{service.title}</h2>
            <p class="mt-3 text-sm text-sand/80">{service.summary}</p>
            <div class="mt-4 space-y-3 text-sm leading-relaxed text-sand/80">
              <p><span class="font-semibold text-white">مناسب لـ:</span> {service.bestFor}</p>
              <p><span class="font-semibold text-white">النتيجة:</span> {service.outcome}</p>
              <p><span class="font-semibold text-white">اختره عندما:</span> {service.chooseWhen}</p>
              <p><span class="font-semibold text-white">الخطوة التالية:</span> {service.nextStep}</p>
            </div>
            <ul class="mt-4 space-y-2 text-sm text-sand/80">
              {service.deliverables.map((item) => <li>- {item}</li>)}
            </ul>
            <div class="mt-5 rounded-2xl border border-white/10 bg-white/[0.03] p-4 text-right">
              <p class="text-xs uppercase tracking-[0.18em] text-gold">دليل من البورتفوليو</p>
              <h3 class="mt-3 text-lg font-semibold text-white">{service.proofTitle}</h3>
              <p class="mt-2 text-sm leading-relaxed text-sand/78">{service.proofSummary}</p>
              <a href={withBase(service.proofHref)} class="gold-link mt-4 inline-block text-sm font-semibold">{service.proofCta}</a>
            </div>
            <div class="mt-5 flex flex-wrap items-center justify-end gap-4 text-sm">
              <a
                href={service.cta === "راسلني على واتساب" ? "https://wa.me/970599797245" : withBase("/ar/contact/")}
                class="rounded-full border border-gold/60 px-4 py-2 font-semibold text-sand transition hover:border-gold hover:text-white"
              >
                {service.cta}
              </a>
            </div>
          </article>
        ))
      }
    </div>
    <div class="mt-8 flex flex-wrap items-center justify-end gap-4 text-sm">
      <a href={withBase("/ar/work/")} class="gold-link font-semibold">اطلع على طبقة الدلائل بكاملها</a>
      <a href={withBase("/ar/museum-of-echoes/")} class="text-sand/75 transition hover:text-white">افتح متحف الأصداء</a>
      <a href={withBase("/ar/literary-reimaginings/")} class="text-sand/75 transition hover:text-white">افتح إعادة تخيّل الروايات</a>
    </div>
  </Section>
  <Section
    title="هل تريد اختيار المسار الأنسب؟"
    copy="إذا كنت غير متأكد من نقطة البداية فابدأ بالعرض التمهيدي. إذا كان الاتجاه واضحا والمشكلة في التنفيذ فاذهب إلى بناء النظام مباشرة. أما إذا كان الاحتياج الحقيقي هو القدرة الداخلية فالورشات هي الأنسب."
    className="text-right"
  >
    <CTAButtons bookHref="/ar/contact/" labels={{ book: "احجز مكالمة", whatsapp: "راسلني على واتساب" }} />
    <div class="mt-4 flex flex-wrap items-center justify-end gap-4 text-sm">
      <a href={withBase("/ar/contact/")} class="gold-link font-semibold">افتح صفحة التواصل</a>
      <a href={withBase("/ar/about/")} class="text-sand/75 transition hover:text-white">اقرأ كيف يجمع هذا النهج بين القصة والتعليم والأنظمة</a>
    </div>
  </Section>
</BaseLayout>
