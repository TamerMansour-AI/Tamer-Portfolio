---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTAButtons from "../../../components/CTAButtons.astro";
import Section from "../../../components/Section.astro";
import SmartImage from "../../../components/SmartImage.astro";
import { servicesAr } from "../../../data/services";
import { withBase } from "../../../utils/withBase";

const serviceSchema = servicesAr.map((service) => ({
  "@type": "Service",
  name: service.title,
  description: service.summary,
  provider: {
    "@type": "Person",
    name: "Tamer Mansour",
    url: "https://tamermansour-ai.github.io/Tamer-Portfolio/ar/"
  },
  areaServed: "Remote",
  availableLanguage: ["Arabic", "English"],
  isRelatedTo: {
    "@type": "CreativeWork",
    name: service.proofTitle,
    url: `https://tamermansour-ai.github.io/Tamer-Portfolio${service.proofHref}`
  }
}));
---
<BaseLayout
  title="الخدمات | فيديو وورشات ومنتجات تعليمية ونماذج رقمية | تامر منصور"
  description="خدمات تامر منصور في إنتاج الفيديو بالذكاء الاصطناعي، الورشات العملية، تصميم المنتجات التعليمية، والنماذج الرقمية ثنائية اللغة."
  path="/ar/services/"
  lang="ar"
  dir="rtl"
  image="/media/services/services-ar.png"
  pageType="CollectionPage"
  schema={serviceSchema}
>
  <section class="container-shell pt-6 sm:pt-8">
    <div class="services-hero overflow-hidden rounded-3xl border border-white/10 bg-white/5">
      <SmartImage
        fallback="/media/services/services-ar.png"
        alt="ملصق تعريفي لخدمات تامر منصور"
        class="services-hero-img w-full"
        loading="eager"
      />
    </div>
  </section>

  <Section
    title="الخدمات"
    copy="أساعد الفرق والمؤسسات على تحويل الأفكار إلى إنتاج بصري بالذكاء الاصطناعي، ورشات عملية، منتجات تعليمية، وتجارب رقمية ثنائية اللغة. كل خدمة هنا مرتبطة بعمل يمكن معاينته."
    className="text-right"
  >
    <div class="mb-8 grid gap-4 md:grid-cols-3">
      <article class="glass-card p-5 text-right">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">فيديو وسرد بصري</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          عندما تحتاج قصة أو درس أو حملة أو فكرة ثقافية إلى فيديو سينمائي قابل للعرض، مع عالم بصري واضح وإيقاع يناسب الجمهور.
        </p>
      </article>
      <article class="glass-card p-5 text-right">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">ورشات وتعلم عملي</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          عندما يحتاج المشاركون إلى ممارسة الذكاء الاصطناعي من خلال أوامر ومصادر ومراجعة وأنشطة حية، لا مجرد شرح نظري.
        </p>
      </article>
      <article class="glass-card p-5 text-right">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">منتجات ونماذج رقمية</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          عندما تحتاج مادة كثيفة أو فكرة جديدة إلى منتج تعليمي، أرشيف، مختبر، صفحة ثنائية اللغة، أو نموذج أولي واضح.
        </p>
      </article>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {
        servicesAr.map((service) => (
          <article class="glass-card p-6 text-right">
            <h2 class="text-xl font-semibold text-white">{service.title}</h2>
            <p class="mt-3 text-sm text-sand/80">{service.summary}</p>
            <div class="mt-4 space-y-3 text-sm leading-relaxed text-sand/80">
              <p><span class="font-semibold text-white">لمن يفيد:</span> {service.bestFor}</p>
              <p><span class="font-semibold text-white">النتيجة:</span> {service.outcome}</p>
              <p><span class="font-semibold text-white">استخدمه عندما:</span> {service.chooseWhen}</p>
              <p><span class="font-semibold text-white">للبدء:</span> {service.nextStep}</p>
            </div>
            <ul class="mt-4 space-y-2 text-sm text-sand/80">
              {service.deliverables.map((item) => <li>- {item}</li>)}
            </ul>
            <div class="mt-5 rounded-2xl border border-white/10 bg-white/[0.03] p-4 text-right">
              <p class="text-xs uppercase tracking-[0.18em] text-gold">دليل من البورتفوليو</p>
              <h3 class="mt-3 text-lg font-semibold text-white">{service.proofTitle}</h3>
              <p class="mt-2 text-sm leading-relaxed text-sand/78">{service.proofSummary}</p>
              <a href={withBase(service.proofHref)} class="gold-link mt-4 inline-block text-sm font-semibold">{service.proofCta}</a>
            </div>
            <div class="mt-5 flex flex-wrap items-center justify-end gap-4 text-sm">
              <a
                href={withBase("/ar/contact/")}
                class="rounded-full border border-gold/60 px-4 py-2 font-semibold text-sand transition hover:border-gold hover:text-white"
              >
                {service.cta}
              </a>
            </div>
          </article>
        ))
      }
    </div>
    <div class="mt-8 flex flex-wrap items-center justify-end gap-4 text-sm">
      <a href={withBase("/ar/proof/")} class="gold-link font-semibold">افتح مركز الأدلة</a>
      <a href={withBase("/ar/work/")} class="text-sand/75 transition hover:text-white">شاهد الأعمال المختارة</a>
      <a href={withBase("/ar/client-ai-production/")} class="text-sand/75 transition hover:text-white">شاهد إنتاج أنبياء البصري</a>
    </div>
  </Section>

  <Section
    title="لست متأكدًا أي خدمة تناسبك؟"
    copy="أرسل الفكرة والجمهور والموعد، وسأقترح أصغر خطوة مفيدة للبدء."
    className="text-right"
  >
    <CTAButtons bookHref="/ar/contact/" labels={{ book: "ابدأ مشروعًا", whatsapp: "راسلني على واتساب" }} />
    <div class="mt-4 flex flex-wrap items-center justify-end gap-4 text-sm">
      <a href={withBase("/ar/contact/")} class="gold-link font-semibold">افتح صفحة التواصل</a>
      <a href={withBase("/ar/about/")} class="text-sand/75 transition hover:text-white">اقرأ كيف يجمع هذا النهج بين القصة والتعليم والأنظمة</a>
    </div>
  </Section>
</BaseLayout>
