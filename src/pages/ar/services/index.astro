---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTAButtons from "../../../components/CTAButtons.astro";
import Section from "../../../components/Section.astro";
import SmartImage from "../../../components/SmartImage.astro";
import { servicesAr } from "../../../data/services";
import { withBase } from "../../../utils/withBase";
---
<BaseLayout
  title="الخدمات | تامر منصور"
  description="خدمات في صياغة قصة العلامة وأنظمة الإنتاج بالذكاء الاصطناعي والورشات التي يقدمها تامر منصور."
  path="/ar/services/"
  lang="ar"
  dir="rtl"
>
  <section class="container-shell pt-6 sm:pt-8">
    <div class="services-hero overflow-hidden rounded-3xl border border-white/10 bg-white/5">
      <SmartImage
        fallback="/media/services/services-ar.png"
        alt="الملصق التعريفي للخدمات"
        class="services-hero-img w-full"
        loading="eager"
      />
    </div>
  </section>

  <Section
    title="خدمات مصممة لخطوة تالية واضحة"
    copy="ابدأ بالعرض التمهيدي عندما يحتاج المشروع إلى وضوح في الاتجاه. انتقل إلى بناء النظام عندما يحتاج الفريق إلى تنفيذ متكرر. وأضف الورشات عندما يصبح نقل القدرة هو الأهم."
    className="text-right"
  >
    <div class="mb-8 grid gap-4 md:grid-cols-3">
      <article class="glass-card p-5 text-right">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">المدخل الأول</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          العرض التمهيدي هو المدخل الأنسب عندما لا تزال القصة أو الخدمة أو الاتجاه البصري بحاجة إلى ضبط أوضح.
        </p>
      </article>
      <article class="glass-card p-5 text-right">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">البناء الأعمق</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          إعداد النظام مناسب للفرق التي تنتج فعلا لكنها تحتاج عملية أنظف ومعيارا أوضح واستقرارا في المخرجات.
        </p>
      </article>
      <article class="glass-card p-5 text-right">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">نقل القدرة</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          الورشات والاستشارات مناسبة عندما يكون المطلوب بناء حكم مهني داخلي لا مجرد تنفيذ وتسليم.
        </p>
      </article>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {
        servicesAr.map((service) => (
          <article class="glass-card p-6 text-right">
            <h2 class="text-xl font-semibold text-white">{service.title}</h2>
            <p class="mt-3 text-sm text-sand/80">{service.summary}</p>
            <div class="mt-4 space-y-3 text-sm leading-relaxed text-sand/80">
              <p><span class="font-semibold text-white">مناسب لـ:</span> {service.bestFor}</p>
              <p><span class="font-semibold text-white">النتيجة:</span> {service.outcome}</p>
              <p><span class="font-semibold text-white">اختره عندما:</span> {service.chooseWhen}</p>
            </div>
            <ul class="mt-4 space-y-2 text-sm text-sand/80">
              {service.deliverables.map((item) => <li>- {item}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
    <a href={withBase("/ar/work/")} class="gold-link mt-8 inline-block text-sm font-semibold">شاهد الأعمال التي تدعم هذا النهج</a>
  </Section>
  <Section
    title="هل تريد اختيار المسار الأنسب؟"
    copy="إذا لم تكن متأكدا من نقطة البداية فابدأ بالعرض التمهيدي. إنه أوضح طريقة لتحديد الاتجاه قبل الالتزام ببناء أعمق."
    className="text-right"
  >
    <CTAButtons bookHref="/ar/contact/" labels={{ book: "احجز مكالمة", whatsapp: "راسلني على واتساب" }} />
    <div class="mt-4 flex flex-wrap items-center justify-end gap-4 text-sm">
      <a href={withBase("/ar/about/")} class="text-sand/75 transition hover:text-white">اقرأ كيف يجمع هذا النهج بين القصة والتعليم والأنظمة</a>
    </div>
  </Section>
</BaseLayout>
