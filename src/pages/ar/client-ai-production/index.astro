---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTAButtons from "../../../components/CTAButtons.astro";
import Section from "../../../components/Section.astro";
import { withBase } from "../../../utils/withBase";
---
<BaseLayout
  title="Anbiya Visuals | إنتاج أفلام قصصية بالذكاء الاصطناعي | تامر منصور"
  description="مثال إنتاج أفلام قصصية كاملة بالذكاء الاصطناعي من تامر منصور، يعرض مقتطفات مختارة من أفلام كاملة عن قصص أنبياء مختلفين."
  path="/ar/client-ai-production/"
  lang="ar"
  dir="rtl"
  image="/media/client-ai-production/anbiya-visuals-arabic-manual-poster.jpg"
  pageType="CreativeWork"
>
  <Section
    title="Anbiya Visuals: إنتاج أفلام قصصية كاملة"
    copy="هذا الفيديو ليس خدمة تجميع لقطات. هو عينة مختارة من أفلام قصصية كاملة عملت عليها لقصص أنبياء مختلفين، ويعرض مستوى الإنتاج السينمائي الذي يمكن بناؤه من الفكرة إلى الفيلم النهائي."
    className="text-right"
  >
    <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
      <div class="glass-card overflow-hidden">
        <div class="relative aspect-video bg-white/5">
          <video
            class="h-full w-full object-cover"
            controls
            preload="metadata"
            playsinline
            poster={withBase("/media/client-ai-production/anbiya-visuals-arabic-manual-poster.jpg")}
            aria-label="عينة من أفلام Anbiya Visuals القصصية بالذكاء الاصطناعي"
          >
            <source
              src={withBase("/media/client-ai-production/anbiya-visuals-arabic-manual-edition.mp4")}
              type="video/mp4"
            />
          </video>
        </div>
      </div>
      <div class="space-y-4">
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">نطاق الإنتاج</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/80">
            في Anbiya Visuals عملت على أفلام كاملة مدعومة بالذكاء الاصطناعي حول قصص أنبياء مختلفين، مع بناء جو سينمائي، لغة بصرية، إيقاع سردي، ومشاهد متتابعة تحمل القصة من بدايتها إلى نهايتها.
          </p>
        </article>
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">ماذا تعرض العينة</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/80">
            الفيديو يجمع لحظات مختارة من تلك الأفلام حتى يفهم الزائر بسرعة نوعية العمل: بناء العالم، إخراج المشاهد، الجو التاريخي، الاستمرارية البصرية، وتحويل الفكرة إلى فيلم قصصي مكتمل.
          </p>
        </article>
      </div>
    </div>
  </Section>

  <Section title="قدرة إنتاج أفلام كاملة" copy="القيمة هنا في القدرة على بناء فيلم قصصي كامل، ثم اختيار مقتطفات خفيفة لعرض النتيجة على الموقع من دون إرهاق الزائر." className="text-right">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {[
        "إنتاج أفلام قصصية سينمائية كاملة لا مجرد ريل قصير",
        "بناء عوالم بصرية مختلفة لقصص أنبياء متعددة",
        "إخراج المشاهد والإيقاع والجو والاستمرارية داخل الحلقة الكاملة",
        "استخدام الذكاء الاصطناعي كخط إنتاج فيلمي من الفكرة إلى النسخة النهائية"
      ].map((item) => (
        <article class="glass-card p-5 text-right">
          <h2 class="text-lg font-semibold text-white">{item}</h2>
        </article>
      ))}
    </div>
  </Section>

  <Section title="قيمة الإنتاج" copy="هذا النوع من العمل يمكن أن يخدم سلاسل تعليمية، مشاريع سرد ثقافي، محتوى مستلهمًا من القصص الدينية، حملات بصرية، ونماذج إعلامية أولية." className="text-right">
    <div class="grid gap-4 md:grid-cols-3">
      {[
        "حلقات كاملة يمكن تحويلها لاحقًا إلى تريلرات أو دروس أو مواد حملات",
        "نظام بصري قابل للتكرار لسلسلة من القصص",
        "عينة عرض تساعد الزائر على فهم حجم العمل السينمائي الأكبر بسرعة"
      ].map((item) => (
        <article class="glass-card p-5 text-right">
          <p class="text-sm leading-relaxed text-sand/82">{item}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section title="تحتاج أفلامًا قصصية كاملة بهذا المستوى؟" copy="أستطيع تحويل قصة، فكرة تعليمية، حملة، أو موجز إبداعي إلى أفلام قصصية سينمائية كاملة بالذكاء الاصطناعي، ثم تجهيز مقتطفات مناسبة للموقع أو العروض أو الحملات." className="text-right">
    <CTAButtons bookHref="/ar/contact/" labels={{ book: "ابدأ إنتاجًا", whatsapp: "راسلني على واتساب" }} />
    <div class="mt-4 flex flex-wrap justify-end gap-4 text-sm">
      <a href={withBase("/ar/services/")} class="gold-link font-semibold">استكشف الخدمات</a>
      <a href={withBase("/ar/work/")} class="text-sand/75 hover:text-white">العودة إلى الأعمال المختارة</a>
    </div>
  </Section>
</BaseLayout>
