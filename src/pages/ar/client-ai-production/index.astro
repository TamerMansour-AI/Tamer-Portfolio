---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTAButtons from "../../../components/CTAButtons.astro";
import Section from "../../../components/Section.astro";
import { withBase } from "../../../utils/withBase";
---
<BaseLayout
  title="Anbiya Visuals AI Story Production | Tamer Mansour"
  description="مثال إنتاج بصري إبداعي من تامر منصور، يعرض تصميم السرد السينمائي، الهوية البصرية، بناء العالم، والإخراج بالذكاء الاصطناعي."
  path="/ar/client-ai-production/"
  lang="ar"
  dir="rtl"
  image="/media/client-ai-production/anbiya-visuals-arabic-manual-poster.jpg"
  pageType="CreativeWork"
>
  <Section
    title="Anbiya Visuals: إنتاج سرد بصري بالذكاء الاصطناعي"
    copy="مثال من عمل نفذته لعميل، يوضح كيف يمكن تحويل فكرة قصصية إلى عالم بصري سينمائي: بطاقات عرض، مشاهد، جو عام، إيقاع، وإخراج مدعوم بالذكاء الاصطناعي."
    className="text-right"
  >
    <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
      <div class="glass-card overflow-hidden">
        <div class="relative aspect-video bg-white/5">
          <video
            class="h-full w-full object-cover"
            controls
            preload="metadata"
            playsinline
            poster={withBase("/media/client-ai-production/anbiya-visuals-arabic-manual-poster.jpg")}
            aria-label="مونتاج عربي لمشروع Anbiya Visuals"
          >
            <source
              src={withBase("/media/client-ai-production/anbiya-visuals-arabic-manual-edition.mp4")}
              type="video/mp4"
            />
          </video>
        </div>
      </div>
      <div class="space-y-4">
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">Anbiya Visuals</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/80">
            في هذا المشروع طورت اتجاهاً بصرياً يحوّل القصص إلى مشاهد ذات هوية واضحة: عناوين سينمائية، لقطات بيئية، إضاءة تاريخية، وإحساس بصري يجعل الفكرة تبدو كمنتج إعلامي قابل للتوسع.
          </p>
        </article>
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">ما الذي أنجزته</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/80">
            العمل يبرز قدرتي على تصميم لغة بصرية، اختيار لقطات مؤثرة، بناء مونتاج متماسك، واستخدام أدوات الذكاء الاصطناعي كخط إنتاج إبداعي من الفكرة إلى نموذج عرض احترافي.
          </p>
        </article>
      </div>
    </div>
  </Section>

  <Section title="ما الذي يثبته هذا العمل" copy="التركيز هنا على جودة الإنتاج وقدرتي على تحويل الفكرة إلى مادة بصرية قابلة للعرض والتطوير." className="text-right">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {[
        "تحويل الفكرة إلى عالم بصري متماسك",
        "تصميم بطاقات عرض وهوية بصرية للمشروع",
        "اختيار لقطات بإحساس سينمائي ووزن عاطفي",
        "استخدام الذكاء الاصطناعي كمنظومة إنتاج لا كأداة صور فقط"
      ].map((item) => (
        <article class="glass-card p-5 text-right">
          <h2 class="text-lg font-semibold text-white">{item}</h2>
        </article>
      ))}
    </div>
  </Section>

  <Section title="قيمة الإنتاج" copy="هذا النوع من العمل يمكن أن يخدم سلاسل تعليمية، مشاريع سرد ثقافي، حملات بصرية، عروض تقديمية، ونماذج إعلامية أولية." className="text-right">
    <div class="grid gap-4 md:grid-cols-3">
      {[
        "مونتاج جاهز يشرح رؤية المنتج بسرعة",
        "نظام بصري قابل للتكرار مع قصص أو حلقات أخرى",
        "هوية تجعل المشروع أسهل في العرض والتذكر"
      ].map((item) => (
        <article class="glass-card p-5 text-right">
          <p class="text-sm leading-relaxed text-sand/82">{item}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section title="تحتاج إنتاجاً بصرياً مشابهاً؟" copy="أستطيع تحويل قصة، فكرة تعليمية، حملة، أو موجز إبداعي إلى اتجاه بصري سينمائي مدعوم بالذكاء الاصطناعي." className="text-right">
    <CTAButtons className="sm:justify-end" />
    <div class="mt-4 flex flex-wrap justify-end gap-4 text-sm">
      <a href={withBase("/ar/services/")} class="gold-link font-semibold">استكشف الخدمات</a>
      <a href={withBase("/ar/work/")} class="text-sand/75 hover:text-white">العودة إلى الأعمال المختارة</a>
    </div>
  </Section>
</BaseLayout>
