---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTAButtons from "../../../components/CTAButtons.astro";
import Section from "../../../components/Section.astro";
import { withBase } from "../../../utils/withBase";

const safeRules = [
  "لا نعرض التسليمات الكاملة للعملاء على الموقع.",
  "لا نعرض النصوص الداخلية أو الملاحظات الخاصة أو تفاصيل الحسابات.",
  "لا نستخدم مواد أفاتار حساسة للهوية إلا من خلال نموذج صناعي بديل.",
  "نستخدم مقتطفات مختارة فقط مع وصف واضح للسياق والحدود."
];
---
<BaseLayout
  title="Client-Safe AI Production Pipeline | Tamer Mansour"
  description="صفحة إثبات آمنة لعرض قدرات تامر منصور في السرد البصري السينمائي بالذكاء الاصطناعي وسير عمل الأفاتار."
  path="/ar/client-ai-production/"
  lang="ar"
  dir="rtl"
  image="/media/client-ai-production/anbiya-visuals-reel-poster.jpg"
  pageType="CreativeWork"
>
  <Section
    title="إنتاج بصري بالذكاء الاصطناعي مع حماية خصوصية العميل"
    copy="طبقة عرض عامة تكفي لإثبات القدرة، من دون نشر الفيديوهات الكاملة أو المواد الخاصة أو أي تفاصيل حساسة من العمل."
    className="text-right"
  >
    <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
      <div class="glass-card overflow-hidden">
        <div class="relative aspect-video bg-white/5">
          <video
            class="h-full w-full object-cover"
            controls
            preload="metadata"
            playsinline
            poster={withBase("/media/client-ai-production/anbiya-visuals-reel-poster.jpg")}
            aria-label="مونتاج آمن للنشر من مشروع Anbiya Visuals مع سياق عربي"
          >
            <source
              src={withBase("/media/client-ai-production/anbiya-visuals-website-edition.mp4")}
              type="video/mp4"
            />
          </video>
        </div>
      </div>
      <div class="space-y-4">
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">Anbiya Visuals</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/80">
            نسخة ويب كاملة وخفيفة من مونتاج مختار وآمن للنشر. أضفت عليها عبارات عربية قصيرة توضّح السرد الصوتي، اللغة البصرية، بناء العالم، والإخراج بالذكاء الاصطناعي من دون كشف التسليمات الكاملة للعميل.
          </p>
        </article>
        <article class="glass-card p-5 text-right">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">Avatar workflow</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/80">
            مشروع الأفاتار يثبت القدرة على بناء سير عمل إنتاجي لفيديوهات الخدمات المهنية، لكن النسخة العامة الأفضل له ستكون نموذجاً صناعياً معاد البناء بدل عرض المواد الأصلية الحساسة.
          </p>
        </article>
      </div>
    </div>
  </Section>

  <Section title="ما الذي يمكن قوله علناً" copy="الصياغة هنا لإثبات القدرة، لا لكشف تفاصيل العميل." className="text-right">
    <div class="grid gap-4 md:grid-cols-3">
      {[
        "اختيار لقطات وسرد بصري سينمائي",
        "تصميم سير عمل قابل للتكرار لفيديوهات الأفاتار",
        "تنظيم التسليمات والمراجعات بطريقة مناسبة للعملاء"
      ].map((item) => (
        <article class="glass-card p-5 text-right">
          <h2 class="text-lg font-semibold text-white">{item}</h2>
        </article>
      ))}
    </div>
  </Section>

  <Section title="قواعد النشر الآمن" copy="هذه القواعد تحمي عمل العميل وتسمح للموقع بإظهار المهارة في الوقت نفسه." className="text-right">
    <div class="grid gap-3 sm:grid-cols-2">
      {safeRules.map((rule) => (
        <article class="glass-card p-5 text-right">
          <p class="text-sm leading-relaxed text-sand/80">{rule}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section title="تحتاج نظام إنتاج مشابه؟" copy="يمكن بيع الخدمة من خلال الاستراتيجية، تصميم اللقطات، التوليد، المراجعة، وتجهيز التسليمات من دون كشف عمل العملاء." className="text-right">
    <CTAButtons className="sm:justify-end" />
    <div class="mt-4 flex flex-wrap justify-end gap-4 text-sm">
      <a href={withBase("/ar/services/")} class="gold-link font-semibold">استكشف الخدمات</a>
      <a href={withBase("/ar/work/")} class="text-sand/75 hover:text-white">العودة إلى الأعمال المختارة</a>
    </div>
  </Section>
</BaseLayout>
