---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTAButtons from "../../components/CTAButtons.astro";
import Section from "../../components/Section.astro";
import { withBase } from "../../utils/withBase";
---
<BaseLayout
  title="Anbiya Visuals AI Story Production | Tamer Mansour"
  description="A creative AI visual production example by Tamer Mansour, showing cinematic story design, visual identity, worldbuilding, and AI-assisted media direction."
  path="/client-ai-production/"
  image="/media/client-ai-production/anbiya-visuals-reel-poster.jpg"
  pageType="CreativeWork"
>
  <Section
    title="Anbiya Visuals: AI story production"
    copy="A client project example showing how narrative ideas can become a cinematic visual world: title cards, atmosphere, scene direction, pacing, and AI-assisted production."
  >
    <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
      <div class="glass-card overflow-hidden">
        <div class="relative aspect-video bg-white/5">
          <video
            class="h-full w-full object-cover"
            controls
            preload="metadata"
            playsinline
            poster={withBase("/media/client-ai-production/anbiya-visuals-reel-poster.jpg")}
            aria-label="Anbiya Visuals AI story production montage"
          >
            <source
              src={withBase("/media/client-ai-production/anbiya-visuals-website-edition.mp4")}
              type="video/mp4"
            />
          </video>
        </div>
      </div>
      <div class="space-y-4">
        <article class="glass-card p-5">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">Anbiya Visuals</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/80">
            I shaped this work as a cinematic narrative showcase: a visual language for prophetic stories, dramatic scene selection, historical atmosphere, and a presentation rhythm that makes the concept feel like a real media product.
          </p>
        </article>
        <article class="glass-card p-5">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">What I produced</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/80">
            The project demonstrates creative direction across AI-generated visuals, title-card design, story mood, montage flow, and the transformation of a written idea into a polished visual proof that can be expanded into longer episodes or campaigns.
          </p>
        </article>
      </div>
    </div>
  </Section>

  <Section title="Creative production shown here" copy="The purpose of this example is to show the visual production capability behind the final montage.">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {[
        "Turning story concepts into a coherent visual world",
        "Designing cinematic title cards and presentation frames",
        "Selecting scenes with atmosphere, pacing, and emotional weight",
        "Using AI tools as a production pipeline, not just image generation"
      ].map((item) => (
        <article class="glass-card p-5">
          <h2 class="text-lg font-semibold text-white">{item}</h2>
        </article>
      ))}
    </div>
  </Section>

  <Section title="Production value" copy="This kind of work can support educational series, cultural storytelling, social campaigns, pitch decks, and proof-of-concept media.">
    <div class="grid gap-4 md:grid-cols-3">
      {[
        "A finished montage that communicates the product vision quickly",
        "A repeatable creative system for future stories and episodes",
        "A visual identity that makes the project easier to pitch and remember"
      ].map((item) => (
        <article class="glass-card p-5">
          <p class="text-sm leading-relaxed text-sand/82">{item}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section title="Need visual production like this?" copy="I can help turn a story, learning concept, brand idea, or campaign brief into a cinematic AI-assisted visual direction.">
    <CTAButtons />
    <div class="mt-4 flex flex-wrap gap-4 text-sm">
      <a href={withBase("/services/")} class="gold-link font-semibold">Explore services</a>
      <a href={withBase("/work/")} class="text-sand/75 hover:text-white">Back to selected work</a>
    </div>
  </Section>
</BaseLayout>
