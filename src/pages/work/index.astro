---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTAButtons from "../../components/CTAButtons.astro";
import Section from "../../components/Section.astro";
import SmartImage from "../../components/SmartImage.astro";
import WorkCard from "../../components/WorkCard.astro";
import { platformProofEn } from "../../data/proof";
import { pinterestPlaceholderEn, workItemsEn } from "../../data/work";
import { withBase } from "../../utils/withBase";

const workSchema = {
  "@type": "ItemList",
  name: "Featured portfolio work",
  itemListElement: workItemsEn.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: item.url?.startsWith("/") ? `https://tamermansour-ai.github.io/Tamer-Portfolio${item.url}` : item.url,
    name: item.title
  }))
};
---
<BaseLayout
  title="Selected Work | AI Stories, Learning Labs, Educational Products, and Digital Platforms | Tamer Mansour"
  description="Selected public work by Tamer Mansour across AI story films, live learning labs, educational products, music videos, book-to-deck systems, and bilingual digital platforms."
  path="/work/"
  pageType="CollectionPage"
  schema={workSchema}
>
  <Section
    title="Selected work"
    copy="A curated view of the work I can show publicly: cinematic AI stories, live learning labs, educational products, music videos, book-to-deck systems, and bilingual digital platforms."
  >
    <div class="mb-8 grid gap-4 md:grid-cols-3">
      <article class="glass-card p-5">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">Cinematic Storytelling</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          AI-assisted films, literary reimaginings, music videos, and visual worlds where the story comes first.
        </p>
      </article>
      <article class="glass-card p-5">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">Learning Systems</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          Workshops, labs, educational packs, and guided experiences that turn AI from a tool mention into practical work.
        </p>
      </article>
      <article class="glass-card p-5">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">Digital Products</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          Bilingual web platforms, archives, prototypes, and product surfaces that make complex material usable.
        </p>
      </article>
    </div>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        workItemsEn.map((item) => <WorkCard item={item} lang="en" imageClass="h-52 w-full object-cover" />)
      }
    </div>
    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      <a
        href={withBase("/museum-of-echoes/")}
        class="group grid gap-5 overflow-hidden rounded-[1.75rem] border border-white/10 bg-[radial-gradient(circle_at_top_left,rgba(212,175,106,0.16),transparent_34%),linear-gradient(145deg,rgba(15,15,15,0.98),rgba(22,22,22,0.96))] p-5 transition hover:border-gold/40 hover:bg-[radial-gradient(circle_at_top_left,rgba(212,175,106,0.2),transparent_34%),linear-gradient(145deg,rgba(15,15,15,0.98),rgba(28,28,28,0.98))]"
      >
        <div class="relative aspect-[4/3] overflow-hidden rounded-[1.35rem] border border-white/10 bg-white/5">
          <SmartImage
            fallback="/media/museum/museum-of-echoes-home.jpg"
            alt="Museum of Echoes featured project preview"
            class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
          />
        </div>
        <div class="space-y-4">
          <p class="text-xs uppercase tracking-[0.2em] text-gold">Featured Project</p>
          <h3 class="text-2xl font-semibold tracking-tight text-white">Museum of Echoes</h3>
          <p class="text-sm leading-relaxed text-sand/80">
            A premium bilingual listening archive that shows how creative direction can extend into product logic, discovery structure, and a public-facing cultural platform.
          </p>
          <div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.16em] text-sand/70">
            <span class="rounded-full border border-white/12 px-3 py-1">Bilingual archive</span>
            <span class="rounded-full border border-white/12 px-3 py-1">Original music</span>
            <span class="rounded-full border border-white/12 px-3 py-1">Product proof</span>
          </div>
          <div class="flex flex-wrap items-center gap-4 text-sm">
            <span class="font-semibold text-gold">Open the project page</span>
            <span class="text-sand/70 transition group-hover:text-white">See the platform context, then open the live archive</span>
          </div>
        </div>
      </a>
      <a
        href={withBase("/literary-reimaginings/")}
        class="group grid gap-5 overflow-hidden rounded-[1.75rem] border border-white/10 bg-[radial-gradient(circle_at_top_left,rgba(212,175,106,0.16),transparent_34%),linear-gradient(145deg,rgba(15,15,15,0.98),rgba(22,22,22,0.96))] p-5 transition hover:border-gold/40 hover:bg-[radial-gradient(circle_at_top_left,rgba(212,175,106,0.2),transparent_34%),linear-gradient(145deg,rgba(15,15,15,0.98),rgba(28,28,28,0.98))]"
      >
      <div class="relative aspect-[4/3] overflow-hidden rounded-[1.35rem] border border-white/10 bg-white/5">
        <SmartImage
          fallback="/media/literary/returning-to-haifa.svg"
          alt="Literary reimaginings featured poster"
          class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
        />
      </div>
      <div class="space-y-4">
        <p class="text-xs uppercase tracking-[0.2em] text-gold">Featured Series</p>
        <h3 class="text-2xl font-semibold tracking-tight text-white">Literary Reimaginings</h3>
        <p class="text-sm leading-relaxed text-sand/80">
          A dedicated storytelling destination for the novel adaptations, with bilingual editions, future-facing context, and a clearer invitation for collaboration, commissioning, or support.
        </p>
        <div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.16em] text-sand/70">
          <span class="rounded-full border border-white/12 px-3 py-1">Men in the Sun</span>
          <span class="rounded-full border border-white/12 px-3 py-1">Returning to Haifa</span>
          <span class="rounded-full border border-white/12 px-3 py-1">Bilingual editions</span>
        </div>
        <div class="flex flex-wrap items-center gap-4 text-sm">
          <span class="font-semibold text-gold">Enter the series</span>
          <span class="text-sand/70 transition group-hover:text-white">A dedicated entry point for the full visual series</span>
        </div>
      </div>
      </a>
    </div>
  </Section>
  <Section
    title="Additional evidence"
    copy="A compact layer for proof that is real but does not always need a full page. Each item focuses on what was built, what it shows, and where it fits in the practice."
  >
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        platformProofEn.map((item) => {
          const href = item.href?.startsWith("http") ? item.href : item.href ? withBase(item.href) : undefined;
          const external = item.href?.startsWith("http");
          return (
            <article class="glass-card p-5">
              <p class="text-xs uppercase tracking-[0.18em] text-gold">{item.category}</p>
              <h3 class="mt-3 text-lg font-semibold leading-tight text-white">{item.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-sand/78">{item.summary}</p>
              {
                href && (
                  <a href={href} target={external ? "_blank" : undefined} rel={external ? "noopener noreferrer" : undefined} class="gold-link mt-4 inline-block text-sm font-semibold">
                    {item.linkLabel ?? "Open proof"}
                  </a>
                )
              }
            </article>
          );
        })
      }
    </div>
  </Section>
  <Section title={pinterestPlaceholderEn.title} copy={pinterestPlaceholderEn.description}>
    <a href={pinterestPlaceholderEn.url} class="gold-link text-sm font-semibold" target="_blank" rel="noopener noreferrer">
      Open Pinterest boards
    </a>
  </Section>
  <Section
    title="Need this kind of direction for a campaign, program, or production system?"
    copy="If the work needs narrative clarity, practical learning, or a stronger production structure, the service paths are mapped."
  >
    <CTAButtons labels={{ book: "Start a project", whatsapp: "Message on WhatsApp" }} />
    <div class="mt-4 flex flex-wrap items-center gap-4 text-sm">
      <a href={withBase("/services/")} class="gold-link font-semibold">Explore services</a>
      <a href={withBase("/about/")} class="text-sand/75 transition hover:text-white">Read how the practice connects story, education, and systems</a>
    </div>
  </Section>
</BaseLayout>
