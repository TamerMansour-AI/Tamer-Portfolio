---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTAButtons from "../../components/CTAButtons.astro";
import Section from "../../components/Section.astro";
import SmartImage from "../../components/SmartImage.astro";
import WorkCard from "../../components/WorkCard.astro";
import { pinterestPlaceholderEn, workItemsEn } from "../../data/work";
import { withBase } from "../../utils/withBase";
---
<BaseLayout
  title="Work | Tamer Mansour"
  description="A flagship selection of literary retelling, digital archive product work, cinematic heritage storytelling, motion-led education, and knowledge design by Tamer Mansour."
  path="/work/"
>
  <Section
    title="Selected work with clear authorship"
    copy="A lean portfolio built around five flagship directions: literary retelling, heritage worldbuilding, bilingual archive product design, motion-led visual education, and structured knowledge design."
  >
    <div class="mb-8 grid gap-4 md:grid-cols-3">
      <article class="glass-card p-5">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">Why These Five</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          Together they show how the practice moves from literary adaptation and cultural atmosphere to digital products, teaching formats, and operational clarity.
        </p>
      </article>
      <article class="glass-card p-5">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">How To Read This Page</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          Some pieces open owned project pages, some link outward, and the deck work opens into an internal gallery built from exported slide materials so visitors can inspect the visual logic without hitting a sign-in wall.
        </p>
      </article>
      <article class="glass-card p-5">
        <p class="text-xs uppercase tracking-[0.18em] text-gold">What This Proves</p>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">
          The same authorship can shape a flagship story piece, a heritage trailer, a bilingual listening platform, a visual learning format, or a dense body of material that needs sharper structure.
        </p>
      </article>
    </div>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        workItemsEn.map((item) => <WorkCard item={item} lang="en" imageClass="h-52 w-full object-cover" />)
      }
    </div>
    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      <a
        href={withBase("/museum-of-echoes/")}
        class="group grid gap-5 overflow-hidden rounded-[1.75rem] border border-white/10 bg-[radial-gradient(circle_at_top_left,rgba(212,175,106,0.16),transparent_34%),linear-gradient(145deg,rgba(15,15,15,0.98),rgba(22,22,22,0.96))] p-5 transition hover:border-gold/40 hover:bg-[radial-gradient(circle_at_top_left,rgba(212,175,106,0.2),transparent_34%),linear-gradient(145deg,rgba(15,15,15,0.98),rgba(28,28,28,0.98))]"
      >
        <div class="relative aspect-[4/3] overflow-hidden rounded-[1.35rem] border border-white/10 bg-white/5">
          <SmartImage
            fallback="/media/museum/museum-of-echoes-home.jpg"
            alt="Museum of Echoes featured project preview"
            class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
          />
        </div>
        <div class="space-y-4">
          <p class="text-xs uppercase tracking-[0.2em] text-gold">Featured Project</p>
          <h3 class="text-2xl font-semibold tracking-tight text-white">Museum of Echoes</h3>
          <p class="text-sm leading-relaxed text-sand/80">
            A premium bilingual listening archive that shows how creative direction can extend into product logic, discovery structure, and a public-facing cultural platform.
          </p>
          <div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.16em] text-sand/70">
            <span class="rounded-full border border-white/12 px-3 py-1">Bilingual archive</span>
            <span class="rounded-full border border-white/12 px-3 py-1">Original music</span>
            <span class="rounded-full border border-white/12 px-3 py-1">Product proof</span>
          </div>
          <div class="flex flex-wrap items-center gap-4 text-sm">
            <span class="font-semibold text-gold">Open the project page</span>
            <span class="text-sand/70 transition group-hover:text-white">See what the platform proves, then open the live archive</span>
          </div>
        </div>
      </a>
      <a
        href={withBase("/literary-reimaginings/")}
        class="group grid gap-5 overflow-hidden rounded-[1.75rem] border border-white/10 bg-[radial-gradient(circle_at_top_left,rgba(212,175,106,0.16),transparent_34%),linear-gradient(145deg,rgba(15,15,15,0.98),rgba(22,22,22,0.96))] p-5 transition hover:border-gold/40 hover:bg-[radial-gradient(circle_at_top_left,rgba(212,175,106,0.2),transparent_34%),linear-gradient(145deg,rgba(15,15,15,0.98),rgba(28,28,28,0.98))]"
      >
      <div class="relative aspect-[4/3] overflow-hidden rounded-[1.35rem] border border-white/10 bg-white/5">
        <SmartImage
          fallback="/media/literary/returning-to-haifa.svg"
          alt="Literary reimaginings featured poster"
          class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
        />
      </div>
      <div class="space-y-4">
        <p class="text-xs uppercase tracking-[0.2em] text-gold">Featured Series</p>
        <h3 class="text-2xl font-semibold tracking-tight text-white">Literary Reimaginings</h3>
        <p class="text-sm leading-relaxed text-sand/80">
          A dedicated storytelling destination for the novel adaptations, with bilingual editions, future-facing context, and a clearer invitation for collaboration, commissioning, or support.
        </p>
        <div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.16em] text-sand/70">
          <span class="rounded-full border border-white/12 px-3 py-1">Men in the Sun</span>
          <span class="rounded-full border border-white/12 px-3 py-1">Returning to Haifa</span>
          <span class="rounded-full border border-white/12 px-3 py-1">Bilingual editions</span>
        </div>
        <div class="flex flex-wrap items-center gap-4 text-sm">
          <span class="font-semibold text-gold">Enter the series</span>
          <span class="text-sand/70 transition group-hover:text-white">A more intentional entry point than a single inline link</span>
        </div>
      </div>
      </a>
    </div>
  </Section>
  <Section title={pinterestPlaceholderEn.title} copy={pinterestPlaceholderEn.description}>
    <a href={pinterestPlaceholderEn.url} class="gold-link text-sm font-semibold" target="_blank" rel="noreferrer">
      Open Pinterest boards
    </a>
  </Section>
  <Section
    title="Need this kind of direction for a campaign, program, or internal system?"
    copy="If the work needs narrative clarity first, start with the sprint. If it needs repeatable production, capability transfer, or internal structure, the service path is already mapped."
  >
    <CTAButtons />
    <div class="mt-4 flex flex-wrap items-center gap-4 text-sm">
      <a href={withBase("/services/")} class="gold-link font-semibold">Explore services</a>
      <a href={withBase("/about/")} class="text-sand/75 transition hover:text-white">Read how the practice connects story, education, and systems</a>
    </div>
  </Section>
</BaseLayout>
