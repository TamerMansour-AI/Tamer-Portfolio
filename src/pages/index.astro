---
import CTAButtons from "../components/CTAButtons.astro";
import SmartImage from "../components/SmartImage.astro";
import Section from "../components/Section.astro";
import WorkCard from "../components/WorkCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pinterestBoardsEn } from "../data/pinterest";
import { platformProofEn, proofMetricsEn } from "../data/proof";
import { servicesEn } from "../data/services";
import { siteData } from "../data/site";
import { featuredWorkEn } from "../data/work";
import { withBase } from "../utils/withBase";

const heroVideo = withBase("/media/hero/hero.mp4");
const heroPoster = withBase("/media/hero/hero-poster.png");
const homeSchema = [
  {
    "@type": "ItemList",
    "@id": "https://tamermansour-ai.github.io/Tamer-Portfolio/#home-highlights",
    name: "Primary proof directions",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        url: "https://tamermansour-ai.github.io/Tamer-Portfolio/museum-of-echoes/",
        name: "Museum of Echoes"
      },
      {
        "@type": "ListItem",
        position: 2,
        url: "https://tamermansour-ai.github.io/Tamer-Portfolio/literary-reimaginings/",
        name: "Literary Reimaginings"
      },
      {
        "@type": "ListItem",
        position: 3,
        url: "https://tamermansour-ai.github.io/Tamer-Portfolio/book-to-decks/",
        name: "Book-to-Deck Reconstructions"
      }
    ]
  }
];
---
<BaseLayout
  title="Tamer Mansour | AI Storytelling, Creative Systems, and Bilingual Workshops"
  description="Portfolio of Tamer Mansour: cinematic AI storytelling, bilingual digital products, educational design, and practical production systems for founders, teams, and institutions."
  path="/"
  image="/media/hero/hero-poster.png"
  pageType="ProfilePage"
  pageHeading={false}
  schema={homeSchema}
>
  <section class="container-shell pt-4 sm:pt-6">
    <div class="overflow-hidden rounded-3xl border border-white/10 bg-white/5">
      <SmartImage
        fallback="/media/hero/hero-poster.png"
        alt="Hero visual poster"
        class="h-[34vh] w-full object-cover sm:h-[44vh] lg:h-[52vh]"
        loading="eager"
      />
    </div>
  </section>

  <section class="container-shell py-14 sm:py-20">
    <div class="grid items-center gap-8 lg:grid-cols-[1.1fr_1fr] lg:gap-10">
      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-gold">Cinematic Storytelling * Practical Training * AI Workflow Design</p>
        <h1 class="mt-5 text-3xl font-semibold leading-tight tracking-tight text-white sm:text-5xl">
          Tamer Mansour builds cinematic AI stories, workshops, and production systems that feel human and hold up in real use.
        </h1>
        <p class="mt-5 max-w-2xl text-sm leading-relaxed text-sand/85 sm:text-base">
          I help founders, teams, and institutions move from vague AI experimentation to clear visual direction, repeatable workflows,
          and stronger audience trust.
        </p>
        <p class="mt-4 max-w-2xl text-sm leading-relaxed text-sand/72 sm:text-[15px]">
          Ramallah-rooted, globally legible, and guided by human judgment at every stage.
        </p>
        <CTAButtons className="mt-7" />
      </div>
      <div class="relative aspect-[4/5] overflow-hidden rounded-3xl border border-white/10 bg-white/5 sm:aspect-video">
        <div
          id="hero-video-fallback"
          class="absolute inset-0 bg-white/5"
        >
          <img src={heroPoster} alt="Cinematic AI storytelling hero preview" class="h-full w-full object-cover" loading="eager" />
        </div>
        <video
          id="hero-video"
          class="absolute inset-0 hidden h-full w-full object-cover"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster={heroPoster}
          aria-label="Cinematic AI storytelling portfolio hero reel"
        >
          <source src={heroVideo} type="video/mp4" />
        </video>
      </div>
    </div>
  </section>

  <section class="container-shell pb-10 sm:pb-12">
    <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 sm:p-6">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <p class="text-xs uppercase tracking-[0.22em] text-gold">Proof Layer</p>
          <h2 class="mt-3 text-xl font-semibold tracking-tight text-white sm:text-2xl">
            Recent proof now connects the creative portfolio to training, apps, systems, and platform activity.
          </h2>
        </div>
        <p class="max-w-xl text-sm leading-relaxed text-sand/75">
          The strongest missing layer was not another claim. It was the evidence chain: workshops delivered, labs designed, app concepts prepared,
          creator-platform activity, and creative AI production demand.
        </p>
      </div>

      <div class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
        {
          proofMetricsEn.map((metric) => (
            <article class="glass-card p-5">
              <p class="text-3xl font-semibold tracking-tight text-white">{metric.value}</p>
              <h3 class="mt-2 text-sm font-semibold text-gold">{metric.label}</h3>
              <p class="mt-3 text-sm leading-relaxed text-sand/78">{metric.detail}</p>
            </article>
          ))
        }
      </div>
      <div class="mt-6 grid gap-3 md:grid-cols-3">
        <a href={withBase("/proof/")} class="glass-card block p-5 hover:border-gold/40">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">Open the proof hub</p>
          <h3 class="mt-3 text-lg font-semibold text-white">Portfolio proof in one place</h3>
        </a>
        <a href={withBase("/workshops/")} class="glass-card block p-5 hover:border-gold/40">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">Workshop proof</p>
          <h3 class="mt-3 text-lg font-semibold text-white">Qattan, Mishkal, AL Mahs3'al, Arab Bank, Birzeit, and more</h3>
        </a>
        <a href={withBase("/notebooklm/")} class="glass-card block p-5 hover:border-gold/40">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">NotebookLM projects</p>
          <h3 class="mt-3 text-lg font-semibold text-white">Source packs, learning systems, and presentation workflows</h3>
        </a>
      </div>
    </div>
  </section>

  <section class="container-shell pb-8 sm:pb-12">
    <a
      href={withBase("/museum-of-echoes/")}
      class="group grid gap-6 overflow-hidden rounded-[2rem] border border-white/10 bg-[radial-gradient(circle_at_top_left,rgba(212,175,106,0.18),transparent_34%),linear-gradient(140deg,rgba(14,14,14,0.98),rgba(24,24,24,0.96))] p-6 transition hover:border-gold/40 hover:bg-[radial-gradient(circle_at_top_left,rgba(212,175,106,0.24),transparent_34%),linear-gradient(140deg,rgba(14,14,14,0.98),rgba(28,28,28,0.98))] lg:grid-cols-[0.95fr_1.05fr] lg:items-center"
    >
      <div class="relative aspect-[4/3] overflow-hidden rounded-[1.5rem] border border-white/10 bg-white/5">
        <SmartImage
          fallback="/media/museum/museum-of-echoes-home.jpg"
          alt="Museum of Echoes project preview"
          class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
        />
      </div>
      <div class="space-y-4">
        <p class="text-xs uppercase tracking-[0.22em] text-gold">Featured Platform Project</p>
        <h2 class="text-2xl font-semibold tracking-tight text-white sm:text-3xl">
          Museum of Echoes brings original music, curation, and bilingual product thinking into one public archive.
        </h2>
        <p class="max-w-2xl text-sm leading-relaxed text-sand/80 sm:text-base">
          A premium listening world where tracks become rooms, batches, and editorial entry points. It proves Tamer&apos;s ability to shape not only media, but the archive logic, interface, and release structure around it.
        </p>
        <div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.18em] text-sand/70">
          <span class="rounded-full border border-white/12 px-3 py-1">Bilingual archive</span>
          <span class="rounded-full border border-white/12 px-3 py-1">Editorial listening</span>
          <span class="rounded-full border border-white/12 px-3 py-1">Live public platform</span>
        </div>
        <div class="flex flex-wrap items-center gap-4 text-sm">
          <span class="font-semibold text-gold">See Museum of Echoes as portfolio proof</span>
          <span class="text-sand/70 transition group-hover:text-white">Open the project page, then explore the live platform</span>
        </div>
      </div>
    </a>
  </section>

  <Section
    title="What I Build"
    copy="I combine cinematic quality, training depth, and practical AI implementation so your team can ship better work consistently."
  >
    <div class="grid gap-4 sm:grid-cols-3">
      <article class="glass-card p-6">
        <h3 class="text-lg font-semibold text-white">Cinematic Production</h3>
        <p class="mt-3 text-sm leading-relaxed text-sand/80">Ads, short films, and visual narratives crafted for emotional clarity and conversion.</p>
      </article>
      <article class="glass-card p-6">
        <h3 class="text-lg font-semibold text-white">Training and Workshops</h3>
        <p class="mt-3 text-sm leading-relaxed text-sand/80">Hands-on programs for teams, creators, and educators ready to level up visual output.</p>
      </article>
      <article class="glass-card p-6">
        <h3 class="text-lg font-semibold text-white">Practical AI Systems</h3>
        <p class="mt-3 text-sm leading-relaxed text-sand/80">Prompt libraries, workflows, and content systems your team can run without chaos.</p>
      </article>
    </div>
  </Section>

  <Section
    title="Selected Work"
    copy="Flagship public work plus recent proof anchors across training, app testing, music/audio, operating systems, and creative AI production workflows."
  >
    <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
      {
        featuredWorkEn.map((item) => <WorkCard item={item} lang="en" imageClass="h-full w-full object-cover" />)
      }
    </div>
    <div class="mt-8 flex flex-wrap items-center gap-4 text-sm">
      <a href={withBase("/work/")} class="gold-link font-semibold">View the flagship work selection</a>
      <a href={withBase("/services/")} class="text-sand/75 transition hover:text-white">See how each direction connects to services</a>
    </div>
  </Section>

  <Section
    title="Additional proof anchors"
    copy="A compact view of the work that supports the portfolio: educational products, workshops, music releases, app concepts, operating systems, and AI production examples."
  >
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        platformProofEn.map((item) => {
          const href = item.href?.startsWith("http") ? item.href : item.href ? withBase(item.href) : undefined;
          const external = item.href?.startsWith("http");
          return (
            <article class="glass-card flex h-full flex-col p-5">
              <p class="text-xs uppercase tracking-[0.18em] text-gold">{item.category}</p>
              <h3 class="mt-3 text-lg font-semibold leading-tight text-white">{item.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-sand/78">{item.summary}</p>
              {
                href && (
                  <a href={href} target={external ? "_blank" : undefined} rel={external ? "noopener noreferrer" : undefined} class="gold-link mt-5 text-sm font-semibold">
                    {item.linkLabel ?? "Open proof"}
                  </a>
                )
              }
            </article>
          );
        })
      }
    </div>
  </Section>

  <section class="container-shell pb-8 sm:pb-12">
    <a
      href={withBase("/literary-reimaginings/")}
      class="group grid gap-6 overflow-hidden rounded-[2rem] border border-white/10 bg-[radial-gradient(circle_at_top_left,rgba(212,175,106,0.18),transparent_34%),linear-gradient(140deg,rgba(14,14,14,0.98),rgba(24,24,24,0.96))] p-6 transition hover:border-gold/40 hover:bg-[radial-gradient(circle_at_top_left,rgba(212,175,106,0.22),transparent_34%),linear-gradient(140deg,rgba(14,14,14,0.98),rgba(28,28,28,0.98))] lg:grid-cols-[0.95fr_1.05fr] lg:items-center"
    >
      <div class="relative aspect-[4/3] overflow-hidden rounded-[1.5rem] border border-white/10 bg-white/5">
        <SmartImage
          fallback="/media/literary/men-in-the-sun.svg"
          alt="Literary reimaginings series poster"
          class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
        />
      </div>
      <div class="space-y-4">
        <p class="text-xs uppercase tracking-[0.22em] text-gold">Featured Storytelling Series</p>
        <h2 class="text-2xl font-semibold tracking-tight text-white sm:text-3xl">
          Literary reimaginings are now a visible storytelling line inside the portfolio.
        </h2>
        <p class="max-w-2xl text-sm leading-relaxed text-sand/80 sm:text-base">
          A more focused destination for Tamer&apos;s AI-based novel reinterpretations, beginning with <span class="text-white">Men in the Sun</span> and <span class="text-white">Returning to Haifa</span>, presented as bilingual cinematic adaptations rather than isolated video links.
        </p>
        <div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.18em] text-sand/70">
          <span class="rounded-full border border-white/12 px-3 py-1">2 novels published</span>
          <span class="rounded-full border border-white/12 px-3 py-1">Arabic + English editions</span>
          <span class="rounded-full border border-white/12 px-3 py-1">Future adaptations</span>
        </div>
        <div class="flex flex-wrap items-center gap-4 text-sm">
          <span class="font-semibold text-gold">Open the literary series</span>
          <span class="text-sand/70 transition group-hover:text-white">See the published works, future direction, and support path</span>
        </div>
      </div>
    </a>
  </section>

  <Section title="Pinterest Boards" copy="Curated visual references for tone, wardrobe, composition, and campaign aesthetics.">
    <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
      {
        pinterestBoardsEn.map((board) => (
          <a href={board.url} target="_blank" rel="noreferrer" class="glass-card block overflow-hidden">
            <div class="relative aspect-[4/3] overflow-hidden bg-[radial-gradient(circle_at_20%_20%,rgba(212,175,106,0.28),transparent_40%),linear-gradient(135deg,rgba(30,30,30,0.98),rgba(18,18,18,0.98))]">
              <img
                src={withBase(board.thumbLocal)}
                data-fallback={withBase("/media/pinterest/boards/gallery-muse.jpg")}
                onerror="if (this.dataset.fallback && this.src !== this.dataset.fallback) { this.src = this.dataset.fallback; } else { this.classList.add('hidden'); }"
                alt={board.title}
                loading="lazy"
                class="h-full w-full object-cover"
              />
            </div>
            <div class="space-y-2 p-5">
              <h3 class="text-lg font-semibold leading-tight text-white">{board.title}</h3>
              <p class="text-sm leading-relaxed text-sand/75">{board.description}</p>
              <p class="text-sm font-semibold text-gold">Open board</p>
            </div>
          </a>
        ))
      }
    </div>
  </Section>

  <Section title="Services" copy="Start with a focused sprint, then expand into system build or team training if the work needs a deeper rollout.">
    <div class="grid gap-4 md:grid-cols-3">
      {
        servicesEn.map((service) => (
          <article class="glass-card p-6">
            <h3 class="text-lg font-semibold text-white">{service.title}</h3>
            <p class="mt-3 text-sm text-sand/80">{service.summary}</p>
          </article>
        ))
      }
    </div>
    <a href={withBase("/services/")} class="gold-link mt-8 inline-block text-sm font-semibold">Explore service details</a>
  </Section>

  <Section
    title="About Tamer"
    copy="I blend narrative craft, AI experimentation, and education to help teams produce visual work that feels alive and performs."
  >
    <a href={withBase("/about/")} class="gold-link text-sm font-semibold">Read the full story</a>
  </Section>

  <Section
    title="Ready to elevate your visual presence?"
    copy="If your next campaign, launch, or program needs a stronger story and sharper creative direction, let's build it properly."
  >
    <CTAButtons />
    <p class="mt-4 text-sm text-sand/70">{siteData.location}</p>
  </Section>
</BaseLayout>

<script>
  const heroVideo = document.getElementById("hero-video");
  const heroFallback = document.getElementById("hero-video-fallback");

  if (heroVideo instanceof HTMLVideoElement && heroFallback instanceof HTMLElement) {
    heroVideo.addEventListener("loadeddata", () => {
      heroVideo.classList.remove("hidden");
      heroFallback.classList.add("hidden");
    });
  }
</script>
