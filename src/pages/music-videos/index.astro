---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTAButtons from "../../components/CTAButtons.astro";
import Section from "../../components/Section.astro";
import { withBase } from "../../utils/withBase";

const videos = [
  {
    title: "My Way",
    context: "English cinematic AI music video",
    poster: "/media/music-videos/my-way-thumb.jpg",
    src: "/media/music-videos/my-way-preview.mp4",
    youtubeUrl: "https://youtu.be/VzHMr0Gw0Pg",
    copy:
      "A moody, cinematic song video built around masks, cost, movement, and self-direction. The public site uses a compressed preview, with the full song available on YouTube."
  },
  {
    title: "Between Me and the Earth",
    context: "Arabic poetic music video",
    poster: "/media/music-videos/between-me-and-earth-thumb.jpg",
    src: "/media/music-videos/between-me-and-earth-preview.mp4",
    youtubeUrl: "https://youtu.be/TcSlQomJ3F0",
    copy:
      "A recent Arabic song visualized through sketch-like frames, personal presence, and quiet narrative movement. The full song is published on YouTube."
  }
];

const fullSongs = [
  {
    title: "بيني وبين الأرض",
    context: "Arabic original song",
    url: "https://youtu.be/TcSlQomJ3F0"
  },
  {
    title: "I Did It My Way",
    context: "Cinematic AI music video",
    url: "https://youtu.be/VzHMr0Gw0Pg"
  },
  {
    title: "What’s Going On × What’s Up",
    context: "2026 remix / original AI song",
    url: "https://youtu.be/N7T1ouDs9bs"
  },
  {
    title: "What’s Going On",
    context: "2026 edition / original AI music",
    url: "https://youtu.be/E6Rt-agXCYM"
  }
];
---
<BaseLayout
  title="Original AI Music Videos | Tamer Mansour"
  description="Original AI music video previews by Tamer Mansour, including My Way and Between Me and the Earth."
  path="/music-videos/"
  image="/media/music-videos/my-way-thumb.jpg"
  pageType="CollectionPage"
>
  <Section
    title="Original AI music videos"
    copy="Recent songs shaped into cinematic visual narratives. The portfolio shows lightweight previews here, with direct links to the full published songs on YouTube."
  >
    <div class="grid gap-6 lg:grid-cols-2">
      {videos.map((video) => (
        <article class="glass-card overflow-hidden">
          <div class="relative bg-black">
            <video
              controls
              playsinline
              preload="metadata"
              poster={withBase(video.poster)}
              class="aspect-video w-full bg-black object-cover"
              aria-label={`${video.title} music video preview`}
            >
              <source src={withBase(video.src)} type="video/mp4" />
            </video>
          </div>
          <div class="space-y-3 p-5">
            <p class="text-xs uppercase tracking-[0.18em] text-gold">{video.context}</p>
            <h2 class="text-2xl font-semibold tracking-tight text-white">{video.title}</h2>
            <p class="text-sm leading-relaxed text-sand/78">{video.copy}</p>
            <a href={video.youtubeUrl} target="_blank" rel="noopener noreferrer" class="gold-link inline-block text-sm font-semibold">
              Watch the full song on YouTube
            </a>
          </div>
        </article>
      ))}
    </div>
  </Section>

  <Section title="Why this belongs in the portfolio" copy="The music work is useful proof because it combines original song direction, prompt-led image systems, editing judgment, motion pacing, and audience-facing video packaging.">
    <div class="grid gap-4 md:grid-cols-3">
      {[
        "Original audio-to-visual direction",
        "Cinematic image system",
        "Short-form release packaging"
      ].map((item) => (
        <article class="glass-card p-5">
          <h2 class="text-lg font-semibold text-white">{item}</h2>
        </article>
      ))}
    </div>
  </Section>

  <Section title="Full songs on YouTube" copy="The full public releases live on Tamer AI’s YouTube channel. The local previews above are just fast portfolio samples.">
    <div class="grid gap-4 md:grid-cols-2">
      {fullSongs.map((song) => (
        <a href={song.url} target="_blank" rel="noopener noreferrer" class="glass-card block p-5 hover:border-gold/40">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">{song.context}</p>
          <h2 class="mt-3 text-lg font-semibold leading-tight text-white">{song.title}</h2>
          <p class="mt-3 text-sm font-semibold text-gold">Open full song on YouTube</p>
        </a>
      ))}
    </div>
  </Section>

  <Section title="Want this kind of music/video direction for a release?" copy="The same workflow can support a song, cultural story, campaign, or short cinematic proof-of-concept.">
    <CTAButtons />
  </Section>
</BaseLayout>
