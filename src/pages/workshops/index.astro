---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTAButtons from "../../components/CTAButtons.astro";
import Section from "../../components/Section.astro";
import SmartImage from "../../components/SmartImage.astro";
import { workshopProofEn } from "../../data/workshops";
import { withBase } from "../../utils/withBase";

const deliveredCount = workshopProofEn.filter((item) => item.status === "Delivered").length;
---
<BaseLayout
  title="AI Workshops and Learning Labs | Tamer Mansour"
  description="Workshop and training proof for Tamer Mansour: practical AI labs, verification workflows, NotebookLM source packs, live workshop websites, and reusable learning assets."
  path="/workshops/"
  pageType="CollectionPage"
>
  <Section
    title="AI workshops that become practical systems"
    copy="The strongest workshop work does not end with slides. It becomes prompts, source packs, exercises, lab websites, recap material, and repeatable learning assets people can keep using."
  >
    <div class="grid gap-4 md:grid-cols-3">
      <article class="glass-card p-5">
        <p class="text-3xl font-semibold text-white">{deliveredCount}+</p>
        <h2 class="mt-2 text-sm font-semibold text-gold">Delivered workshop lanes</h2>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">Across media, artists, education, youth, parents, newsroom, and professional teams.</p>
      </article>
      <article class="glass-card p-5">
        <p class="text-3xl font-semibold text-white">2</p>
        <h2 class="mt-2 text-sm font-semibold text-gold">University / student tracks</h2>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">Birzeit AI fluency and job-search readiness materials, activities, and exports.</p>
      </article>
      <article class="glass-card p-5">
        <p class="text-3xl font-semibold text-white">1</p>
        <h2 class="mt-2 text-sm font-semibold text-gold">NotebookLM learning system</h2>
        <p class="mt-3 text-sm leading-relaxed text-sand/78">Arab Bank parent workshop source-pack logic, prompts, templates, and outputs.</p>
      </article>
    </div>
  </Section>

  <Section title="Named training proof" copy="These are the clearest proof entries for real audiences, workshop systems, and practical outcomes.">
    <div class="grid gap-4 md:grid-cols-2">
      {
        workshopProofEn.map((item) => (
          <article class="glass-card p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <h2 class="text-xl font-semibold leading-tight text-white">{item.title}</h2>
              <span class="rounded-full border border-white/15 px-3 py-1 text-xs uppercase tracking-[0.14em] text-sand/70">{item.status}</span>
            </div>
            <p class="mt-2 text-sm font-semibold text-gold">{item.audience}</p>
            <p class="mt-4 text-sm leading-relaxed text-sand/80">{item.proof}</p>
            <p class="mt-3 text-sm leading-relaxed text-sand/68">{item.outcome}</p>
          </article>
        ))
      }
    </div>
  </Section>

  <Section title="Live lab outcomes" copy="Two recent workshop systems now have public links and visual proof, showing practical outcomes from the training work.">
    <div class="grid gap-6 lg:grid-cols-2">
      <article class="glass-card overflow-hidden">
        <div class="relative aspect-video bg-white/5">
          <SmartImage fallback="/media/workshops/ai-verification-workflow-map.jpg" alt="AI Verification Lab workflow map" class="h-full w-full object-cover" />
        </div>
        <div class="space-y-3 p-5">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">Journalism verification lab</p>
          <h2 class="text-xl font-semibold text-white">AI Verification Lab for Journalists</h2>
          <p class="text-sm leading-relaxed text-sand/78">Bilingual guides, verification workflows, NotebookLM recap visuals, and an Arabic-first workshop hub for responsible AI use in journalism.</p>
            <a href="https://ai-verification-lab.pages.dev" target="_blank" rel="noopener noreferrer" class="gold-link text-sm font-semibold">Open live lab</a>
        </div>
      </article>
      <article class="glass-card overflow-hidden">
        <div class="relative aspect-video bg-white/5">
          <SmartImage fallback="/media/workshops/birzeit-ai-fluency-home.jpg" alt="Birzeit AI Fluency Lab home screen" class="h-full w-full object-cover" />
        </div>
        <div class="space-y-3 p-5">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">University AI fluency lab</p>
          <h2 class="text-xl font-semibold text-white">Birzeit AI Fluency Lab 2026</h2>
          <p class="text-sm leading-relaxed text-sand/78">A live workshop system with landing, join, activity, result, guided review, and shared display moments for practical AI fluency sessions.</p>
            <a href="https://birzeit-ai-fluency-lab-2026.pages.dev" target="_blank" rel="noopener noreferrer" class="gold-link text-sm font-semibold">Open live lab</a>
        </div>
      </article>
    </div>
  </Section>

  <Section title="What the workshops prove" copy="The core value is not tool demonstration. It is the ability to turn fast-moving AI tools into structured practice for real people.">
    <div class="grid gap-4 md:grid-cols-3">
      {["Prompting as thinking", "Responsible review", "Source-grounded workflows", "Visual direction", "NotebookLM source packs", "Interactive lab websites"].map((item) => (
        <article class="glass-card p-5">
          <h2 class="text-lg font-semibold text-white">{item}</h2>
        </article>
      ))}
    </div>
    <div class="mt-8 flex flex-wrap gap-4 text-sm">
      <a href={withBase("/notebooklm/")} class="gold-link font-semibold">See NotebookLM projects</a>
      <a href={withBase("/proof/")} class="text-sand/75 transition hover:text-white">Back to proof hub</a>
    </div>
  </Section>

  <Section title="Need a workshop or training system?" copy="The portfolio now shows the proof. The next step is choosing the right scope and audience.">
    <CTAButtons labels={{ book: "Start a workshop", whatsapp: "Message on WhatsApp" }} />
  </Section>
</BaseLayout>
