---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTAButtons from "../../components/CTAButtons.astro";
import Section from "../../components/Section.astro";
import SmartImage from "../../components/SmartImage.astro";
import { withBase } from "../../utils/withBase";

const storeUrl = "https://www.teacherspayteachers.com/store/primary-learning-visualised";
const productLinks = [
  {
    title: "Pushes & Pulls Lesson Pack",
    href: "https://www.teacherspayteachers.com/Product/Forces-Motion-Lesson-1-Complete-Bundle-Pushes-Pulls-15481050"
  },
  {
    title: "Friction Lesson Bundle",
    href: "https://www.teacherspayteachers.com/Product/Forces-Motion-Lesson-2-Friction-Lesson-Bundle-Slides-Video-Worksheets-15549604"
  }
];

const samples = [
  {
    title: "Marketplace cover",
    src: "/media/education-products/tpt-pushes-pulls-cover.jpg",
    copy: "Clear product packaging for a Year 3 science lesson pack."
  },
  {
    title: "Slide logic",
    src: "/media/education-products/tpt-force-direction-slide.jpg",
    copy: "Simple visual explanation of force direction and classroom concepts."
  },
  {
    title: "Misconception check",
    src: "/media/education-products/tpt-friction-stop-think.jpg",
    copy: "Student-facing checks designed for discussion and correction."
  },
  {
    title: "Printable worksheet",
    src: "/media/education-products/tpt-friction-worksheet.jpg",
    copy: "Printable worksheet proof for the offline classroom layer."
  }
];
---
<BaseLayout
  title="Primary Learning Visualised | TPT Educational Product Proof"
  description="A portfolio case page for Primary Learning Visualised, a Teachers Pay Teachers educational product lane with visual lesson packs, worksheets, quick checks, and video previews."
  path="/education-products/"
  image="/media/education-products/tpt-pushes-pulls-cover.jpg"
  pageType="CreativeWork"
>
  <Section
    title="Primary Learning Visualised"
    copy="A public educational-product lane built with a Qatar-based teaching partner: primary science lesson packs, video previews, worksheets, quick checks, and teacher-ready product packaging."
  >
    <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
      <div class="glass-card overflow-hidden">
        <div class="relative aspect-video bg-white/5">
          <SmartImage fallback="/media/education-products/tpt-pushes-pulls-cover.jpg" alt="Pushes and Pulls lesson pack cover" class="h-full w-full object-cover" loading="eager" />
        </div>
      </div>
      <div class="space-y-4">
        <article class="glass-card p-5">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">What the product shows</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/80">
            This is not a loose visual experiment. It is a repeatable product system: curriculum idea, visual lesson, worksheet, assessment, answer key, thumbnail, listing copy, and marketplace packaging.
          </p>
        </article>
        <article class="glass-card p-5">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">Public proof</p>
          <div class="mt-3 flex flex-wrap gap-3 text-sm">
            <a href={storeUrl} target="_blank" rel="noopener noreferrer" class="gold-link font-semibold">Open TPT store</a>
            {productLinks.map((item) => (
              <a href={item.href} target="_blank" rel="noopener noreferrer" class="text-sand/75 hover:text-white">{item.title}</a>
            ))}
          </div>
        </article>
        <article class="glass-card p-5">
          <p class="text-xs uppercase tracking-[0.18em] text-gold">Product value</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/80">
            The work connects teaching judgment, AI-assisted production, visual explanation, marketplace packaging, and classroom-ready artifacts.
          </p>
        </article>
      </div>
    </div>
  </Section>

  <Section title="Selected product assets" copy="A curated sample of the marketplace-facing assets: covers, slide logic, checks, worksheets, and classroom-ready product visuals.">
    <div class="grid gap-5 sm:grid-cols-2">
      {samples.map((sample) => (
        <article class="glass-card overflow-hidden">
          <div class="relative aspect-video bg-white/5">
            <SmartImage fallback={sample.src} alt={sample.title} class="h-full w-full object-cover" />
          </div>
          <div class="p-5">
            <h2 class="text-lg font-semibold text-white">{sample.title}</h2>
            <p class="mt-2 text-sm leading-relaxed text-sand/75">{sample.copy}</p>
          </div>
        </article>
      ))}
    </div>
  </Section>

  <Section title="Short video proof" copy="A lightweight preview clip shows the animated lesson direction in a fast, web-friendly format.">
    <div class="overflow-hidden rounded-2xl border border-white/10 bg-white/5">
      <video controls playsinline preload="metadata" poster={withBase("/media/education-products/tpt-pushes-pulls-cover.jpg")} class="w-full" aria-label="Pushes and Pulls lesson pack video preview">
        <source src={withBase("/media/education-products/tpt-pushes-pulls-preview.mp4")} type="video/mp4" />
      </video>
    </div>
  </Section>

  <Section title="Need an educational product system?" copy="The same workflow can turn a lesson, source pack, workshop, or training idea into clearer assets people can actually use.">
    <CTAButtons labels={{ book: "Start a project", whatsapp: "Message on WhatsApp" }} />
  </Section>
</BaseLayout>
