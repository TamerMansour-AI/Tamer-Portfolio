---
import SmartImage from "./SmartImage.astro";
import type { WorkItem } from "../data/work";
import { withBase } from "../utils/withBase";

type Props = {
  item: WorkItem;
  lang?: "en" | "ar";
  imageClass?: string;
};

const { item, lang = "en", imageClass = "absolute inset-0 h-full w-full object-contain" } = Astro.props;
const isArabic = lang === "ar";
const hasLink = Boolean(item.url);
const isExternal = item.url?.startsWith("http");
const primaryHref = item.url ? (isExternal ? item.url : withBase(item.url)) : undefined;
const linkLabel = item.linkLabel ?? (isArabic ? "شاهد العمل" : "View project");
const hasSecondaryLink = Boolean(item.secondaryUrl);
const secondaryIsExternal = item.secondaryUrl?.startsWith("http");
const secondaryHref = item.secondaryUrl
  ? secondaryIsExternal
    ? item.secondaryUrl
    : withBase(item.secondaryUrl)
  : undefined;
const secondaryLabel = item.secondaryLabel ?? (isArabic ? "رابط إضافي" : "Supporting link");
---
<article class="glass-card overflow-hidden">
  {
    hasLink ? (
      <a href={primaryHref} target={isExternal ? "_blank" : undefined} rel={isExternal ? "noreferrer" : undefined} class="block">
        <div class="relative aspect-video w-full bg-white/5">
          <SmartImage
            candidates={item.thumbRemoteCandidates}
            fallback={item.thumbLocal}
            alt={item.title}
            class={imageClass}
          />
        </div>
      </a>
    ) : (
      <div class="relative aspect-video w-full bg-white/5">
        <SmartImage
          candidates={item.thumbRemoteCandidates}
          fallback={item.thumbLocal}
          alt={item.title}
          class={imageClass}
        />
      </div>
    )
  }
  <div class="space-y-3 p-5">
    <p class="text-xs uppercase tracking-[0.18em] text-gold">{item.type}</p>
    <h3 class="text-lg font-semibold leading-tight text-white">{item.title}</h3>
    <p class="text-sm font-medium text-white/80">{item.context}</p>
    <p class="whitespace-pre-line text-sm leading-relaxed text-sand/75">{item.description}</p>
    <div class="flex flex-wrap gap-2">
      {item.tags.map((tag) => <span class="rounded-full border border-white/15 px-2.5 py-1 text-xs text-sand/80">{tag}</span>)}
    </div>
    {item.note && <p class="text-xs leading-relaxed text-sand/58">{item.note}</p>}
    {
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
        {
          hasLink ? (
            <a href={primaryHref} target={isExternal ? "_blank" : undefined} rel={isExternal ? "noreferrer" : undefined} class="text-sm font-semibold text-gold">
              {linkLabel}
            </a>
          ) : (
            <p class="text-sm font-semibold text-sand/55">{isArabic ? "مرجع مختار من الاستوديو" : "Selected studio reference"}</p>
          )
        }
        {
          hasSecondaryLink && (
            <a
              href={secondaryHref}
              target={secondaryIsExternal ? "_blank" : undefined}
              rel={secondaryIsExternal ? "noreferrer" : undefined}
              class="text-xs font-medium text-sand/70 transition hover:text-white"
            >
              {secondaryLabel}
            </a>
          )
        }
      </div>
    }
  </div>
</article>
