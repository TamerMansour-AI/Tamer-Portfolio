---
import CTAButtons from "./CTAButtons.astro";
import Section from "./Section.astro";
import SmartImage from "./SmartImage.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { deckItemsAr, deckItemsEn } from "../data/decks";
import { withBase } from "../utils/withBase";

type Props = {
  lang?: "en" | "ar";
  path: string;
};

const { lang = "en", path } = Astro.props;
const isArabic = lang === "ar";
const decks = isArabic ? deckItemsAr : deckItemsEn;
const pageUrl = `https://tamermansour-ai.github.io/Tamer-Portfolio${path}`;

const labels = isArabic
  ? {
      title: "تحويل الكتب إلى عروض بصرية | تامر منصور",
      description: "أمثلة من تحويل الكتب والمواد الكثيفة إلى عروض بصرية وأنظمة معرفة قابلة للتعليم والعرض.",
      heroTitle: "تحويل الكتب إلى عروض بصرية",
      heroCopy:
        "أمثلة مختارة توضح كيف يمكن تحويل كتب وأفكار كثيفة إلى شرائح واضحة تساعد على التعليم، الإحاطة، والنقاش.",
      cardOneTitle: "تصميم معرفة",
      cardOneBody: "القيمة ليست في الزينة البصرية فقط، بل في ترتيب الحجة والتسلسل والإيقاع حتى تصبح المادة أسهل في الفهم.",
      cardTwoTitle: "من مادة كثيفة إلى عرض واضح",
      cardTwoBody: "كل مثال يحاول استخراج بنية قابلة للقراءة من كتاب أو فكرة معقدة، ثم تحويلها إلى نظام بصري متماسك.",
      cardThreeTitle: "أصول قابلة للاستخدام",
      cardThreeBody: "يمكن استخدام هذا النوع من العمل في التدريب، العروض، الشرح، المنتجات التعليمية، أو جلسات النقاش.",
      jumpLabel: "اذهب إلى المعاينة",
      deckSectionTitle: "معاينات مختارة",
      deckSectionCopy: "المعرض داخل الموقع حتى يمكن معاينة منطق الشرائح بسرعة من دون الاعتماد على روابط خارجية.",
      previewLabel: "افتح الشريحة",
      bottomTitle: "هل تحتاج تحويل مادة كثيفة إلى نظام بصري؟",
      bottomCopy: "يمكن استخدام نفس المسار مع كتب، تقارير، مصادر تدريب، أو أفكار تحتاج بنية أوضح.",
      serviceLink: "استكشف الخدمات",
      workLink: "العودة إلى الأعمال المختارة",
      serviceHref: "/ar/services/",
      workHref: "/ar/work/",
      bookHref: "/ar/contact/",
      ctaLabels: { book: "ابدأ مشروعًا", whatsapp: "راسلني على واتساب" },
      schemaName: "تحويل الكتب إلى عروض بصرية",
      schemaDescription: "معرض أعمال يحول الكتب والمواد الفكرية الكثيفة إلى عروض بصرية أوضح للتدريس والإحاطة والنقاش."
    }
  : {
      title: "Book-to-Deck Reconstructions | Knowledge Design and Educational Slides | Tamer Mansour",
      description:
        "Book-to-deck reconstructions by Tamer Mansour, showing how dense books and source material can become clearer teaching systems, briefings, and visual arguments.",
      heroTitle: "Book-to-deck reconstructions",
      heroCopy:
        "Selected deck examples showing how dense books and fictional premises can become clear visual systems for teaching, briefing, and strategic communication.",
      cardOneTitle: "Knowledge design",
      cardOneBody: "The value is not decorative slide design. It is the ability to structure argument, sequence, pace, and legibility.",
      cardTwoTitle: "Dense material made usable",
      cardTwoBody: "Each example extracts a readable structure from a book or complex premise, then turns it into a coherent visual system.",
      cardThreeTitle: "Reusable assets",
      cardThreeBody: "This kind of work can support training, presentations, explainers, educational products, and facilitated discussion.",
      jumpLabel: "Jump to preview",
      deckSectionTitle: "Selected deck previews",
      deckSectionCopy: "The gallery lives inside the site so the deck logic can be inspected without a sign-in wall.",
      previewLabel: "Open slide",
      bottomTitle: "Need to turn dense material into a clearer visual system?",
      bottomCopy: "The same workflow can support books, reports, training sources, or ideas that need stronger structure.",
      serviceLink: "Explore services",
      workLink: "Back to selected work",
      serviceHref: "/services/",
      workHref: "/work/",
      bookHref: "/contact/",
      ctaLabels: { book: "Start a project", whatsapp: "Message on WhatsApp" },
      schemaName: "Book-to-Deck Reconstructions",
      schemaDescription:
        "A curated gallery showing how dense books and source material can become clear visual systems for teaching, briefing, and structured communication."
    };

const deckSchema = {
  "@type": "CollectionPage",
  name: labels.schemaName,
  description: labels.schemaDescription,
  url: pageUrl,
  creator: {
    "@type": "Person",
    name: "Tamer Mansour"
  },
  hasPart: decks.map((deck) => ({
    "@type": "CreativeWork",
    name: deck.title,
    description: deck.description
  }))
};
---
<BaseLayout
  title={labels.title}
  description={labels.description}
  path={path}
  lang={lang}
  dir={isArabic ? "rtl" : "ltr"}
  image="/media/decks/digital-prometheus/cover.jpg"
  pageType="CollectionPage"
  schema={deckSchema}
>
  <Section title={labels.heroTitle} copy={labels.heroCopy} className={isArabic ? "text-right" : ""}>
    <div class="mb-8 grid gap-4 md:grid-cols-3">
      {[
        [labels.cardOneTitle, labels.cardOneBody],
        [labels.cardTwoTitle, labels.cardTwoBody],
        [labels.cardThreeTitle, labels.cardThreeBody]
      ].map(([title, body]) => (
        <article class={`glass-card p-5 ${isArabic ? "text-right" : ""}`}>
          <p class="text-xs uppercase tracking-[0.18em] text-gold">{title}</p>
          <p class="mt-3 text-sm leading-relaxed text-sand/78">{body}</p>
        </article>
      ))}
    </div>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        decks.map((deck) => (
          <a href={`#${deck.slug}`} class={`glass-card overflow-hidden transition hover:border-gold/40 hover:bg-white/10 ${isArabic ? "text-right" : ""}`}>
            <div class="relative aspect-video w-full bg-white/5">
              <SmartImage fallback={deck.cover} alt={deck.title} class="h-full w-full object-contain p-2" />
            </div>
            <div class="space-y-3 p-5">
              <p class="text-xs uppercase tracking-[0.18em] text-gold">{deck.category}</p>
              <h2 class="text-lg font-semibold leading-tight text-white">{deck.title}</h2>
              <p class="text-sm font-medium text-white/80">{deck.context}</p>
              <span class="text-sm font-semibold text-gold">{labels.jumpLabel}</span>
            </div>
          </a>
        ))
      }
    </div>
  </Section>

  <Section title={labels.deckSectionTitle} copy={labels.deckSectionCopy} className={isArabic ? "text-right" : ""}>
    <div class="space-y-8">
      {
        decks.map((deck) => (
          <article id={deck.slug} class="glass-card overflow-hidden p-5 sm:p-6">
            <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
              <div class={`space-y-4 ${isArabic ? "text-right" : ""}`}>
                <p class="text-xs uppercase tracking-[0.18em] text-gold">{deck.category}</p>
                <h2 class="text-2xl font-semibold leading-tight text-white">{deck.title}</h2>
                <p class="text-sm font-medium text-white/82">{deck.context}</p>
                <p class="text-sm leading-relaxed text-sand/78">{deck.description}</p>
                <div class={`flex flex-wrap gap-2 ${isArabic ? "justify-end" : ""}`}>
                  {deck.tags.map((tag) => <span class="rounded-full border border-white/15 px-2.5 py-1 text-xs text-sand/80">{tag}</span>)}
                </div>
                <p class="text-xs leading-relaxed text-sand/58">{deck.note}</p>
              </div>
              <a href={withBase(deck.cover)} target="_blank" rel="noopener noreferrer" class="group block overflow-hidden rounded-2xl border border-white/10 bg-white/5">
                <div class="relative aspect-video w-full bg-white/5">
                  <SmartImage fallback={deck.cover} alt={deck.title} class="h-full w-full object-contain p-2 transition duration-300 group-hover:scale-[1.01]" />
                </div>
              </a>
            </div>
            <div class="mt-6 grid gap-4 sm:grid-cols-2">
              {
                deck.previews.map((preview) => (
                  <a href={withBase(preview.src)} target="_blank" rel="noopener noreferrer" class="group overflow-hidden rounded-2xl border border-white/10 bg-white/5">
                    <div class="relative aspect-video w-full bg-white/5">
                      <SmartImage fallback={preview.src} alt={`${deck.title} - ${preview.label}`} class="h-full w-full object-contain p-2 transition duration-300 group-hover:scale-[1.01]" />
                    </div>
                    <div class={`flex items-center justify-between gap-3 px-4 py-3 text-sm ${isArabic ? "flex-row-reverse text-right" : ""}`}>
                      <span class="text-sand/78">{preview.label}</span>
                      <span class="font-semibold text-gold">{labels.previewLabel}</span>
                    </div>
                  </a>
                ))
              }
            </div>
          </article>
        ))
      }
    </div>
  </Section>

  <Section title={labels.bottomTitle} copy={labels.bottomCopy} className={isArabic ? "text-right" : ""}>
    <CTAButtons bookHref={labels.bookHref} labels={labels.ctaLabels} className={isArabic ? "sm:justify-end" : ""} />
    <div class={`mt-4 flex flex-wrap items-center gap-4 text-sm ${isArabic ? "justify-end" : ""}`}>
      <a href={withBase(labels.serviceHref)} class="gold-link font-semibold">{labels.serviceLink}</a>
      <a href={withBase(labels.workHref)} class="text-sand/75 transition hover:text-white">{labels.workLink}</a>
    </div>
  </Section>
</BaseLayout>
