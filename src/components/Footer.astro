---
import { currentYear, siteData, whatsappLinks } from "../data/site";

type Props = {
  lang?: "en" | "ar";
  dir?: "ltr" | "rtl";
};

const { lang = "en", dir = "ltr" } = Astro.props;
const isArabic = lang === "ar";
const labels = isArabic
  ? {
      contact: "تواصل",
      email: "البريد:",
      whatsapp: "واتساب:",
      location: "الموقع",
      rights: "كل الحقوق محفوظة."
    }
  : {
      contact: "Contact",
      email: "Email:",
      whatsapp: "WhatsApp:",
      location: "Location",
      rights: "All rights reserved."
    };
---
<footer class="border-t border-white/10 py-10" dir={dir}>
  <div class="container-shell grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    <div>
      <p class="text-sm font-semibold text-white">{siteData.name}</p>
      <p class="mt-3 text-sm leading-relaxed text-sand/75">{siteData.title}</p>
    </div>

    <div>
      <p class="text-sm font-semibold text-white">{labels.contact}</p>
      <ul class="mt-3 space-y-2 text-sm text-sand/80">
        <li>
          <span class="text-sand/60">{labels.email}</span>
          <a class={`gold-link ${isArabic ? "mr-2" : "ml-2"}`} href={`mailto:${siteData.email}`}>{siteData.email}</a>
        </li>
        <li>
          <span class="text-sand/60">{labels.whatsapp}</span>
          <a class={`gold-link ${isArabic ? "mr-2" : "ml-2"}`} target="_blank" rel="noopener noreferrer" href={whatsappLinks.primary}>{siteData.whatsappPrimary}</a>
        </li>
        <li>
          <span class="text-sand/60">{labels.whatsapp}</span>
          <a class={`gold-link ${isArabic ? "mr-2" : "ml-2"}`} target="_blank" rel="noopener noreferrer" href={whatsappLinks.secondary}>{siteData.whatsappSecondary}</a>
        </li>
      </ul>
    </div>

    <div>
      <p class="text-sm font-semibold text-white">{labels.location}</p>
      <p class="mt-3 text-sm text-sand/80">{siteData.location}</p>
      <div class="mt-4 flex flex-wrap gap-3 text-sm text-sand/80">
        <a class="gold-link" href={siteData.social.instagram} target="_blank" rel="noopener noreferrer">Instagram</a>
        <a class="gold-link" href={siteData.social.youtube} target="_blank" rel="noopener noreferrer">YouTube</a>
        <a class="gold-link" href={siteData.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a class="gold-link" href={siteData.social.facebook} target="_blank" rel="noopener noreferrer">Facebook</a>
        <a class="gold-link" href={siteData.social.tiktok} target="_blank" rel="noopener noreferrer">TikTok</a>
        <a class="gold-link" href={siteData.social.pinterest} target="_blank" rel="noopener noreferrer">Pinterest</a>
        <a class="gold-link" href={siteData.social.superteam} target="_blank" rel="noopener noreferrer">Superteam</a>
      </div>
    </div>
  </div>

  <div class="container-shell mt-8 border-t border-white/10 pt-4 text-xs text-sand/60">
    &copy; {currentYear} {siteData.name}. {labels.rights}
  </div>
</footer>
