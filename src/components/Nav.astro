---
import { navAr, navEn, type NavItem } from "../data/nav";
import { siteData } from "../data/site";
import { withBase } from "../utils/withBase";

type Props = {
  lang?: "en" | "ar";
  dir?: "ltr" | "rtl";
};

const { lang = "en", dir = "ltr" } = Astro.props;
const currentPathRaw = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const stripBase = (path: string) => {
  if (path.startsWith(base)) {
    const value = path.slice(base.length - 1);
    return value.startsWith("/") ? value : `/${value}`;
  }
  return path;
};

const currentPath = stripBase(currentPathRaw);
const items: NavItem[] = lang === "ar" ? navAr : navEn;

const switchTargets: Record<string, { en: string; ar?: string }> = {
  "/": { en: "/", ar: "/ar/" },
  "/about/": { en: "/about/", ar: "/ar/about/" },
  "/ar/about/": { en: "/about/", ar: "/ar/about/" },
  "/blog/": { en: "/blog/", ar: "/ar/blog/" },
  "/ar/blog/": { en: "/blog/", ar: "/ar/blog/" },
  "/blog/jump-before-you-feel-ready/": { en: "/blog/jump-before-you-feel-ready/", ar: "/ar/blog/jump-before-you-feel-ready/" },
  "/ar/blog/jump-before-you-feel-ready/": { en: "/blog/jump-before-you-feel-ready/", ar: "/ar/blog/jump-before-you-feel-ready/" },
  "/book-to-decks/": { en: "/book-to-decks/", ar: "/ar/book-to-decks/" },
  "/en/book-to-decks/": { en: "/book-to-decks/", ar: "/ar/book-to-decks/" },
  "/ar/book-to-decks/": { en: "/book-to-decks/", ar: "/ar/book-to-decks/" },
  "/client-ai-production/": { en: "/client-ai-production/", ar: "/ar/client-ai-production/" },
  "/ar/client-ai-production/": { en: "/client-ai-production/", ar: "/ar/client-ai-production/" },
  "/contact/": { en: "/contact/", ar: "/ar/contact/" },
  "/ar/contact/": { en: "/contact/", ar: "/ar/contact/" },
  "/education-products/": { en: "/education-products/", ar: "/ar/education-products/" },
  "/ar/education-products/": { en: "/education-products/", ar: "/ar/education-products/" },
  "/literary-reimaginings/": { en: "/literary-reimaginings/", ar: "/ar/literary-reimaginings/" },
  "/en/literary-reimaginings/": { en: "/literary-reimaginings/", ar: "/ar/literary-reimaginings/" },
  "/ar/literary-reimaginings/": { en: "/literary-reimaginings/", ar: "/ar/literary-reimaginings/" },
  "/museum-of-echoes/": { en: "/museum-of-echoes/", ar: "/ar/museum-of-echoes/" },
  "/en/museum-of-echoes/": { en: "/museum-of-echoes/", ar: "/ar/museum-of-echoes/" },
  "/ar/museum-of-echoes/": { en: "/museum-of-echoes/", ar: "/ar/museum-of-echoes/" },
  "/music-videos/": { en: "/music-videos/", ar: "/ar/music-videos/" },
  "/ar/music-videos/": { en: "/music-videos/", ar: "/ar/music-videos/" },
  "/proof/": { en: "/proof/" },
  "/services/": { en: "/services/", ar: "/ar/services/" },
  "/ar/services/": { en: "/services/", ar: "/ar/services/" },
  "/work/": { en: "/work/", ar: "/ar/work/" },
  "/en/work/": { en: "/work/", ar: "/ar/work/" },
  "/ar/work/": { en: "/work/", ar: "/ar/work/" },
  "/workshops/": { en: "/workshops/" },
  "/notebooklm/": { en: "/notebooklm/" }
};

const switchPath = (path: string) => {
  const clean = path.endsWith("/") ? path : `${path}/`;
  const target = switchTargets[clean];
  if (lang === "ar") return target?.en ?? "/";
  return target?.ar ?? "/ar/";
};

const isActive = (href: string) => {
  const normalizedCurrent = currentPath.endsWith("/") ? currentPath : `${currentPath}/`;
  return normalizedCurrent === href;
};
---
<header class="sticky top-0 z-30 border-b border-white/10 bg-ink/85 backdrop-blur">
  <div class="container-shell py-4">
    <div class="flex items-center justify-between gap-4">
      <a href={withBase(lang === "ar" ? "/ar/" : "/")} class="text-sm font-semibold tracking-[0.2em] text-white">
        {siteData.name}
      </a>
      <button
        id="menu-toggle"
        class="inline-flex rounded-md border border-white/20 p-2 text-sand md:hidden"
        aria-expanded="false"
        aria-controls="primary-nav"
        aria-label={lang === "ar" ? "فتح القائمة الرئيسية" : "Open main menu"}
      >
        <span class="sr-only">Menu</span>
        <svg viewBox="0 0 20 20" class="h-5 w-5 fill-current">
          <path d="M3 5h14v2H3zM3 9h14v2H3zM3 13h14v2H3z"></path>
        </svg>
      </button>
    </div>
    <nav id="primary-nav" class="hidden flex-col gap-3 pt-4 md:flex md:flex-row md:items-center md:justify-end md:gap-6 md:pt-0" dir={dir}>
      {
        items.map((item) => (
          <a
            href={withBase(item.href)}
            class={`text-sm ${isActive(item.href) ? "text-gold" : "text-sand/80 hover:text-white"}`}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={withBase(switchPath(currentPath))}
        class="mt-1 w-max rounded-full border border-gold/60 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-gold hover:border-gold hover:text-gold-soft md:mt-0"
      >
        {lang === "ar" ? "EN" : "AR"}
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const nav = document.getElementById("primary-nav");
  if (toggle && nav) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      nav.classList.toggle("hidden");
      nav.classList.toggle("flex");
    });
  }
</script>
