---
import { siteData } from "../data/site";

type Props = {
  title: string;
  description: string;
  path?: string;
  lang?: string;
  image?: string;
  pageType?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
};

const { title, description, path = "/", lang = "en", image, pageType = "WebPage", schema: pageSchema } = Astro.props;

const base = import.meta.env.BASE_URL;
const site = Astro.site?.toString() ?? "https://tamermansour-ai.github.io";
const normalizedPath = path.startsWith("/") ? path.slice(1) : path;
const urlForPath = (value: string) => {
  const normalizedValue = value.startsWith("/") ? value.slice(1) : value;
  return new URL(`${base}${normalizedValue}`, site).toString();
};
const canonical = urlForPath(path);
const ogImage = image ? urlForPath(image) : new URL(`${base}assets/og.svg`, site).toString();
const strippedPath = normalizedPath.replace(/^(ar|en)\//, "");
const englishPath = strippedPath ? `/${strippedPath}` : "/";
const arabicPath = strippedPath ? `/ar/${strippedPath}` : "/ar/";
const englishAlternate = urlForPath(englishPath);
const arabicAlternate = urlForPath(arabicPath);
const homeUrl = urlForPath("/");
const sameAs = Object.values(siteData.social);
const localeLabels = {
  en: {
    home: "Home",
    work: "Work",
    services: "Services",
    about: "About",
    contact: "Contact",
    blog: "Blog",
    "museum-of-echoes": "Museum of Echoes",
    "literary-reimaginings": "Literary Reimaginings",
    "book-to-decks": "Book-to-Deck Reconstructions"
  },
  ar: {
    home: "الرئيسية",
    work: "الأعمال",
    services: "الخدمات",
    about: "من أنا",
    contact: "تواصل",
    blog: "المدونة",
    "museum-of-echoes": "متحف الأصداء",
    "literary-reimaginings": "إعادة تخيّل الروايات بصريًا",
    "book-to-decks": "إعادة بناء الكتب كعروض شرائح"
  }
} as const;
const labels = lang === "ar" ? localeLabels.ar : localeLabels.en;
const segments = strippedPath.split("/").filter(Boolean);
const localePrefix = lang === "ar" ? "/ar" : "";
const breadcrumbBasePath = lang === "ar" ? "/ar/" : "/";
const breadcrumbItems = [
  {
    "@type": "ListItem",
    position: 1,
    name: labels.home,
    item: urlForPath(breadcrumbBasePath)
  }
];

segments.forEach((segment, index) => {
  const segmentPath = `${localePrefix}/${segments.slice(0, index + 1).join("/")}/`;
  breadcrumbItems.push({
    "@type": "ListItem",
    position: index + 2,
    name: labels[segment as keyof typeof labels] ?? segment.replace(/-/g, " "),
    item: urlForPath(segmentPath)
  });
});

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "@id": `${canonical}#breadcrumb`,
  itemListElement: breadcrumbItems
};

const webPageSchema = {
  "@type": pageType,
  "@id": `${canonical}#webpage`,
  url: canonical,
  name: title,
  description,
  inLanguage: lang,
  isPartOf: {
    "@id": `${homeUrl}#website`
  },
  about: {
    "@id": `${homeUrl}#person`
  },
  breadcrumb: {
    "@id": `${canonical}#breadcrumb`
  }
};

const extraSchema = Array.isArray(pageSchema) ? pageSchema : pageSchema ? [pageSchema] : [];
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${homeUrl}#website`,
      url: homeUrl,
      name: siteData.name,
      description: siteData.description,
      inLanguage: ["en", "ar"]
    },
    {
      "@type": "Person",
      "@id": `${homeUrl}#person`,
      name: siteData.name,
      jobTitle: siteData.title,
      description: siteData.description,
      url: homeUrl,
      image: ogImage,
      email: `mailto:${siteData.email}`,
      address: {
        "@type": "PostalAddress",
        addressLocality: "Ramallah",
        addressCountry: "PS"
      },
      knowsLanguage: ["en", "ar"],
      sameAs
    },
    webPageSchema,
    breadcrumbSchema,
    ...extraSchema
  ]
};
---
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content="index,follow" />
<meta name="theme-color" content="#0f0f0f" />
<meta property="og:type" content={pageType === "Article" ? "article" : "website"} />
<meta property="og:site_name" content={siteData.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={`${siteData.name} portfolio preview`} />
<meta property="og:locale" content={lang === "ar" ? "ar_PS" : "en_US"} />
<meta property="og:locale:alternate" content={lang === "ar" ? "en_US" : "ar_PS"} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:url" content={canonical} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={`${siteData.name} portfolio preview`} />
<link rel="canonical" href={canonical} />
<link rel="alternate" hreflang="en" href={englishAlternate} />
<link rel="alternate" hreflang="ar" href={arabicAlternate} />
<link rel="alternate" hreflang="x-default" href={englishAlternate} />
<meta name="author" content={siteData.name} />
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
